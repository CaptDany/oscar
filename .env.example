.PHONY: help build test lint migrate migrate-down generate dev docker-up docker-down

help: ## Show this help
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = ":.*?## "}; {printf "\033[36m%-15s\033[0m %s\n", $$1, $$2}'

## App
APP_PORT=8080
APP_ENV=development
APP_SECRET=change-me-in-production-32bytes!!
APP_BASE_URL=http://localhost:8080

## Database
DATABASE_URL=postgres://oscar:oscar@localhost:5432/oscar?sslmode=disable
DATABASE_MAX_CONNS=25
DATABASE_MAX_IDLE=5

## Redis
REDIS_URL=redis://localhost:6379

## Storage (MinIO)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=oscar
MINIO_USE_SSL=false

## Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost

## SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

## Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_PORT=9090

## Feature flags
FEATURE_EMAIL_SYNC=false
FEATURE_SMS=false
FEATURE_WHATSAPP=false
FEATURE_API_KEYS=true
