---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Persons">
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Persons</h1>
      <p class="text-gray-500">Manage your contacts and leads</p>
    </div>
    <button id="add-person-btn" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      Add Person
    </button>
  </div>

  <!-- Filters -->
  <div class="mb-6 flex gap-4">
    <div class="flex-1">
      <input type="text" id="search-input" placeholder="Search persons..." class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
    </div>
    <select id="type-filter" class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
      <option value="">All Types</option>
      <option value="lead">Lead</option>
      <option value="contact">Contact</option>
      <option value="customer">Customer</option>
    </select>
  </div>

  <!-- Persons Table -->
  <div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Phone</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Company</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody id="persons-table-body" class="divide-y divide-gray-200">
          <tr>
            <td colspan="6" class="px-6 py-12 text-center text-gray-400">
              <svg class="w-8 h-8 mx-auto mb-2 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              Loading persons...
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  <div id="pagination" class="mt-4 flex items-center justify-between">
    <p class="text-sm text-gray-500">Showing <span id="showing-start">0</span> to <span id="showing-end">0</span> of <span id="total-count">0</span> results</p>
    <div class="flex gap-2">
      <button id="prev-btn" class="px-3 py-1 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 disabled:opacity-50" disabled>Previous</button>
      <button id="next-btn" class="px-3 py-1 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 disabled:opacity-50" disabled>Next</button>
    </div>
  </div>

  <!-- Add/Edit Modal -->
  <div id="person-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md mx-4">
      <div class="p-6 border-b border-gray-200">
        <h2 id="modal-title" class="text-lg font-semibold text-gray-900">Add Person</h2>
      </div>
      <div id="form-error" class="hidden mx-6 mt-4 p-3 bg-red-50 border border-red-200 rounded-lg">
        <p id="form-error-message" class="text-sm text-red-600"></p>
      </div>
      <form id="person-form" class="p-6 space-y-4">
        <input type="hidden" id="person-id">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
          <select id="person-type" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
            <option value="lead">Lead</option>
            <option value="contact">Contact</option>
            <option value="customer">Customer</option>
          </select>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
            <input type="text" id="person-first-name" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
            <input type="text" id="person-last-name" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input type="email" id="person-email" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
          <div class="flex gap-2">
            <select id="person-country-code" class="w-28 px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
              <option value="+1">+1 (US)</option>
              <option value="+44">+44 (UK)</option>
              <option value="+55">+55 (BR)</option>
              <option value="+52">+52 (MX)</option>
              <option value="+54">+54 (AR)</option>
              <option value="+56">+56 (CL)</option>
              <option value="+57">+57 (CO)</option>
              <option value="+593">+593 (EC)</option>
              <option value="+51">+51 (PE)</option>
              <option value="+58">+58 (VE)</option>
              <option value="">Other</option>
            </select>
            <input type="tel" id="person-phone" placeholder="(555) 123-4567" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Company</label>
          <select id="person-company" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
            <option value="">No company</option>
          </select>
        </div>
        <div class="flex justify-end gap-3 pt-4">
          <button type="button" id="cancel-btn" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { auth, api } from '../lib/api';

    let currentPage = 1;
    const limit = 20;
    let currentSearch = '';
    let currentType = '';
    let companiesCache: any[] = [];

    function toTitleCase(str: string): string {
      if (!str) return '';
      return str.replace(/\w\S*/g, (txt) => {
        return txt.charAt(0).toUpperCase() + txt.substring(1).toLowerCase();
      });
    }

    function formatPhoneForDisplay(value: string): string {
      if (!value) return '';
      const digits = value.replace(/\D/g, '');
      if (digits.length <= 3) return digits;
      if (digits.length <= 6) return `(${digits.slice(0, 3)}) ${digits.slice(3)}`;
      return `(${digits.slice(0, 3)}) ${digits.slice(3, 6)}-${digits.slice(6, 10)}`;
    }

    function stripPhoneFormatting(value: string): string {
      return value.replace(/\D/g, '');
    }

    function isValidEmail(email: string): boolean {
      if (!email) return true;
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return emailRegex.test(email);
    }

    function showFieldError(inputId: string, message: string) {
      const input = document.getElementById(inputId);
      if (!input) return;
      
      let errorEl = input.parentElement?.querySelector('.field-error');
      if (!errorEl) {
        errorEl = document.createElement('p');
        errorEl.className = 'field-error text-red-500 text-xs mt-1';
        input.parentElement?.appendChild(errorEl);
      }
      errorEl.textContent = message;
      input.classList.add('border-red-500');
    }

    function clearFieldError(inputId: string) {
      const input = document.getElementById(inputId);
      if (!input) return;
      
      const errorEl = input.parentElement?.querySelector('.field-error');
      if (errorEl) errorEl.remove();
      input.classList.remove('border-red-500');
    }

    function clearAllErrors() {
      ['person-first-name', 'person-last-name', 'person-email', 'person-phone'].forEach(clearFieldError);
      const formError = document.getElementById('form-error');
      if (formError) formError.classList.add('hidden');
    }

    function showFormError(message: string) {
      const formError = document.getElementById('form-error');
      const formErrorMessage = document.getElementById('form-error-message');
      if (formError && formErrorMessage) {
        formErrorMessage.textContent = message;
        formError.classList.remove('hidden');
      }
    }

    function getFieldInputId(field: string): string | null {
      const baseField = field.replace(/\[\d+\]/, '');
      const fieldMap: Record<string, string> = {
        'first_name': 'person-first-name',
        'last_name': 'person-last-name',
        'email': 'person-email',
        'phone': 'person-phone',
      };
      return fieldMap[baseField] || null;
    }

    async function loadPersons() {
      const token = auth.token;
      if (!token) {
        window.location.href = '/login';
        return;
      }

      try {
        const data = await api.persons.list(token, {
          limit,
          search: currentSearch,
          type: currentType,
        });

        const tbody = document.getElementById('persons-table-body')!;
        
        if (data.data && data.data.length > 0) {
          tbody.innerHTML = data.data.map((person: any) => `
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center mr-3">
                    <span class="text-primary-600 font-medium">${(person.first_name || '')[0] || ''}${(person.last_name || '')[0] || ''}</span>
                  </div>
                  <div>
                    <div class="text-sm font-medium text-gray-900">${person.first_name || ''} ${person.last_name || ''}</div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${person.email?.[0] || '-'}</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${person.phone?.[0] || '-'}</td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-2 py-1 text-xs font-medium rounded-full ${
                  person.type === 'lead' ? 'bg-yellow-100 text-yellow-800' :
                  person.type === 'contact' ? 'bg-blue-100 text-blue-800' :
                  'bg-green-100 text-green-800'
                }">${(person.type || '').charAt(0).toUpperCase() + (person.type || '').slice(1)}</span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${person.company_name || '-'}</td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                <button onclick="editPerson('${person.id}')" class="text-primary-600 hover:text-primary-900 mr-3">Edit</button>
                <button onclick="deletePerson('${person.id}')" class="text-red-600 hover:text-red-900">Delete</button>
              </td>
            </tr>
          `).join('');
        } else {
          tbody.innerHTML = `
            <tr>
              <td colspan="6" class="px-6 py-12 text-center text-gray-400">
                No persons found. Add your first person to get started.
              </td>
            </tr>
          `;
        }

        const total = data.meta?.total || 0;
        const start = (currentPage - 1) * limit + 1;
        const end = Math.min(currentPage * limit, total);
        
        document.getElementById('showing-start')!.textContent = total > 0 ? start.toString() : '0';
        document.getElementById('showing-end')!.textContent = end.toString();
        document.getElementById('total-count')!.textContent = total.toString();
        
        const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
        const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = end >= total;

      } catch (error: any) {
        console.error('Failed to load persons:', error);
        if (error.message?.includes('Unauthorized')) {
          auth.clear();
          window.location.href = '/login';
        }
      }
    }

    async function loadCompanies() {
      if (companiesCache.length > 0) return companiesCache;
      
      try {
        const data = await api.companies.list(auth.token!, { limit: 100, includeTotal: true });
        companiesCache = data.data || [];
      } catch (error) {
        console.error('Failed to load companies:', error);
        companiesCache = [];
      }
      return companiesCache;
    }

    async function openModal(person?: any) {
      const modal = document.getElementById('person-modal')!;
      const title = document.getElementById('modal-title')!;
      const companySelect = document.getElementById('person-company') as HTMLSelectElement;
      
      const companies = await loadCompanies();
      companySelect.innerHTML = '<option value="">No company</option>' + 
        companies.map((c: any) => `<option value="${c.id}">${c.name}</option>`).join('');
      
      if (person) {
        title.textContent = 'Edit Person';
        (document.getElementById('person-id') as HTMLInputElement).value = person.id;
        (document.getElementById('person-type') as HTMLSelectElement).value = person.type || 'lead';
        (document.getElementById('person-first-name') as HTMLInputElement).value = person.first_name || '';
        (document.getElementById('person-last-name') as HTMLInputElement).value = person.last_name || '';
        (document.getElementById('person-email') as HTMLInputElement).value = person.email?.[0] || '';
        (document.getElementById('person-phone') as HTMLInputElement).value = formatPhoneForDisplay(person.phone?.[0]) || '';
        companySelect.value = person.company_id || '';
      } else {
        title.textContent = 'Add Person';
        (document.getElementById('person-id') as HTMLInputElement).value = '';
        (document.getElementById('person-form') as HTMLFormElement).reset();
        companySelect.value = '';
      }
      
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeModal() {
      const modal = document.getElementById('person-modal')!;
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    (window as any).editPerson = async function(id: string) {
      try {
        const response = await api.persons.get(auth.token!, id);
        openModal(response.data);
      } catch (error) {
        console.error('Failed to load person:', error);
      }
    };

    (window as any).deletePerson = async function(id: string) {
      if (!confirm('Are you sure you want to delete this person?')) return;
      
      try {
        await api.persons.delete(auth.token!, id);
        loadPersons();
      } catch (error) {
        console.error('Failed to delete person:', error);
        alert('Failed to delete person');
      }
    };

    document.addEventListener('DOMContentLoaded', () => {
      loadPersons();

      document.getElementById('add-person-btn')?.addEventListener('click', () => openModal());
      document.getElementById('cancel-btn')?.addEventListener('click', closeModal);
      
      document.getElementById('person-modal')?.addEventListener('click', (e) => {
        if (e.target === e.currentTarget) closeModal();
      });

      document.getElementById('person-first-name')?.addEventListener('input', (e) => {
        const input = e.target as HTMLInputElement;
        const cursorPos = input.selectionStart || 0;
        input.value = toTitleCase(input.value);
        input.setSelectionRange(cursorPos, cursorPos);
      });

      document.getElementById('person-last-name')?.addEventListener('input', (e) => {
        const input = e.target as HTMLInputElement;
        const cursorPos = input.selectionStart || 0;
        input.value = toTitleCase(input.value);
        input.setSelectionRange(cursorPos, cursorPos);
      });

      document.getElementById('person-phone')?.addEventListener('input', (e) => {
        const input = e.target as HTMLInputElement;
        const cursorPos = input.selectionStart || 0;
        input.value = formatPhoneForDisplay(input.value);
        input.setSelectionRange(cursorPos, cursorPos);
      });

      document.getElementById('person-email')?.addEventListener('blur', (e) => {
        const input = e.target as HTMLInputElement;
        if (input.value && !isValidEmail(input.value)) {
          showFieldError('person-email', 'Please enter a valid email address');
        } else {
          clearFieldError('person-email');
        }
      });

      document.getElementById('person-email')?.addEventListener('input', (e) => {
        clearFieldError('person-email');
      });

      document.getElementById('person-first-name')?.addEventListener('input', () => clearFieldError('person-first-name'));
      document.getElementById('person-last-name')?.addEventListener('input', () => clearFieldError('person-last-name'));
      document.getElementById('person-phone')?.addEventListener('input', () => clearFieldError('person-phone'));

      let searchTimeout: number;
      document.getElementById('search-input')?.addEventListener('input', (e) => {
        clearTimeout(searchTimeout);
        searchTimeout = window.setTimeout(() => {
          currentSearch = (e.target as HTMLInputElement).value;
          currentPage = 1;
          loadPersons();
        }, 300);
      });

      document.getElementById('type-filter')?.addEventListener('change', (e) => {
        currentType = (e.target as HTMLSelectElement).value;
        currentPage = 1;
        loadPersons();
      });

      document.getElementById('prev-btn')?.addEventListener('click', () => {
        if (currentPage > 1) {
          currentPage--;
          loadPersons();
        }
      });

      document.getElementById('next-btn')?.addEventListener('click', () => {
        currentPage++;
        loadPersons();
      });

      document.getElementById('person-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const id = (document.getElementById('person-id') as HTMLInputElement).value;
        const data: any = {
          type: (document.getElementById('person-type') as HTMLSelectElement).value,
          first_name: (document.getElementById('person-first-name') as HTMLInputElement).value,
          last_name: (document.getElementById('person-last-name') as HTMLInputElement).value,
        };
        
        const email = (document.getElementById('person-email') as HTMLInputElement).value;
        if (email) data.email = [email];
        
        const phone = stripPhoneFormatting((document.getElementById('person-phone') as HTMLInputElement).value);
        if (phone) data.phone = [phone];

        const companyId = (document.getElementById('person-company') as HTMLSelectElement).value;
        if (companyId) data.company_id = companyId;

        clearAllErrors();
        
        try {
          if (id) {
            await api.persons.update(auth.token!, id, data);
          } else {
            await api.persons.create(auth.token!, data);
          }
          closeModal();
          loadPersons();
        } catch (error: any) {
          console.error('Failed to save person:', error);
          
          if (error.response?.data?.error) {
            const apiError = error.response.data.error;
            if (typeof apiError === 'string') {
              showFormError(apiError);
            } else if (apiError.details && apiError.details.length > 0) {
              let hasFieldErrors = false;
              for (const detail of apiError.details) {
                const inputId = getFieldInputId(detail.field);
                if (inputId) {
                  showFieldError(inputId, detail.message);
                  hasFieldErrors = true;
                } else {
                  showFormError(detail.message);
                }
              }
              if (!hasFieldErrors) {
                showFormError('Validation failed. Please check your input.');
              }
            } else {
              showFormError('Failed to save person. Please try again.');
            }
          } else {
            showFormError('Failed to save person. Please try again.');
          }
        }
      });
    });
  </script>
</AppLayout>
