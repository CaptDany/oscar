---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Activities">
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Activities</h1>
      <p class="text-gray-500">Track tasks, calls, and meetings</p>
    </div>
    <button id="add-activity-btn" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      Add Activity
    </button>
  </div>

  <!-- Filters -->
  <div class="mb-6 flex gap-4">
    <div class="flex-1">
      <input type="text" id="search-input" placeholder="Search activities..." class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
    </div>
    <select id="type-filter" class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
      <option value="">All Types</option>
      <option value="call">Call</option>
      <option value="meeting">Meeting</option>
      <option value="task">Task</option>
      <option value="email">Email</option>
    </select>
  </div>

  <!-- Activities List -->
  <div id="activities-list" class="space-y-4">
    <div class="bg-white rounded-xl shadow-sm p-6 text-center text-gray-400">
      <svg class="w-8 h-8 mx-auto mb-2 animate-spin" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      Loading activities...
    </div>
  </div>

  <!-- Pagination -->
  <div id="pagination" class="mt-6 flex items-center justify-between">
    <p class="text-sm text-gray-500">Showing <span id="showing-start">0</span> to <span id="showing-end">0</span> of <span id="total-count">0</span> results</p>
    <div class="flex gap-2">
      <button id="prev-btn" class="px-3 py-1 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 disabled:opacity-50" disabled>Previous</button>
      <button id="next-btn" class="px-3 py-1 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 disabled:opacity-50" disabled>Next</button>
    </div>
  </div>

  <!-- Add/Edit Modal -->
  <div id="activity-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md mx-4">
      <div class="p-6 border-b border-gray-200">
        <h2 id="modal-title" class="text-lg font-semibold text-gray-900">Add Activity</h2>
      </div>
      <form id="activity-form" class="p-6 space-y-4">
        <input type="hidden" id="activity-id">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
          <input type="text" id="activity-title" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
          <select id="activity-type" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
            <option value="task">Task</option>
            <option value="call">Call</option>
            <option value="meeting">Meeting</option>
            <option value="email">Email</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Due Date</label>
          <input type="datetime-local" id="activity-due-date" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
          <textarea id="activity-description" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"></textarea>
        </div>
        <div class="flex justify-end gap-3 pt-4">
          <button type="button" id="cancel-btn" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { auth, api } from '../lib/api';

    let currentPage = 1;
    const limit = 20;
    let currentSearch = '';
    let currentType = '';

    function timeAgo(date: string): string {
      const now = new Date();
      const then = new Date(date);
      const seconds = Math.floor((now.getTime() - then.getTime()) / 1000);

      if (seconds < 60) return 'just now';
      if (seconds < 3600) return `${Math.floor(seconds / 60)}m ago`;
      if (seconds < 86400) return `${Math.floor(seconds / 3600)}h ago`;
      if (seconds < 604800) return `${Math.floor(seconds / 86400)}d ago`;
      return then.toLocaleDateString();
    }

    function formatDate(date: string): string {
      return new Date(date).toLocaleString();
    }

    async function loadActivities() {
      const token = auth.token;
      if (!token) {
        window.location.href = '/login';
        return;
      }

      try {
        const data = await api.activities.list(token, {
          limit,
          offset: (currentPage - 1) * limit,
          type: currentType,
        });

        const list = document.getElementById('activities-list')!;

        if (data.data && data.data.length > 0) {
          list.innerHTML = data.data.map((activity: any) => `
            <div class="bg-white rounded-xl shadow-sm p-6">
              <div class="flex items-start justify-between">
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-full flex items-center justify-center ${
                    activity.type === 'call' ? 'bg-green-100 text-green-600' :
                    activity.type === 'meeting' ? 'bg-blue-100 text-blue-600' :
                    activity.type === 'email' ? 'bg-purple-100 text-purple-600' :
                    'bg-yellow-100 text-yellow-600'
                  }">
                    ${activity.type === 'call' ? `
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                      </svg>
                    ` : activity.type === 'meeting' ? `
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                    ` : activity.type === 'email' ? `
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                      </svg>
                    ` : `
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                      </svg>
                    `}
                  </div>
                  <div>
                    <h3 class="text-sm font-medium text-gray-900">${activity.subject || 'Untitled Activity'}</h3>
                    <p class="text-xs text-gray-500 mt-1">${activity.type?.charAt(0).toUpperCase() + activity.type?.slice(1) || 'Task'}</p>
                    ${activity.body ? `<p class="text-sm text-gray-600 mt-2">${activity.body}</p>` : ''}
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <div class="text-right mr-4">
                    <p class="text-xs text-gray-500">Due</p>
                    <p class="text-sm text-gray-700">${activity.due_at ? formatDate(activity.due_at) : 'No due date'}</p>
                  </div>
                  <button onclick="toggleActivity('${activity.id}', '${activity.status}')" class="px-3 py-1 text-xs font-medium rounded-lg border ${activity.status === 'completed' ? 'bg-green-100 text-green-700 border-green-200 hover:bg-green-200' : 'bg-blue-600 text-white border-blue-600 hover:bg-blue-700'}">
                    ${activity.status === 'completed' ? 'Completed' : 'Mark as completed'}
                  </button>
                  <button onclick="editActivity('${activity.id}')" class="p-2 text-gray-400 hover:text-gray-600">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                    </svg>
                  </button>
                  <button onclick="deleteActivity('${activity.id}')" class="p-2 text-gray-400 hover:text-red-600">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          `).join('');
        } else {
          list.innerHTML = `
            <div class="bg-white rounded-xl shadow-sm p-6 text-center text-gray-400">
              No activities found. Add your first activity to get started.
            </div>
          `;
        }

        const total = data.meta?.total || 0;
        const start = (currentPage - 1) * limit + 1;
        const end = Math.min(currentPage * limit, total);

        document.getElementById('showing-start')!.textContent = total > 0 ? start.toString() : '0';
        document.getElementById('showing-end')!.textContent = end.toString();
        document.getElementById('total-count')!.textContent = total.toString();

        const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
        const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = end >= total;

      } catch (error: any) {
        console.error('Failed to load activities:', error);
        if (error.message?.includes('Unauthorized')) {
          auth.clear();
          window.location.href = '/login';
        }
      }
    }

    function openModal(activity?: any) {
      const modal = document.getElementById('activity-modal')!;
      const title = document.getElementById('modal-title')!;

      if (activity) {
        title.textContent = 'Edit Activity';
        (document.getElementById('activity-id') as HTMLInputElement).value = activity.id;
        (document.getElementById('activity-title') as HTMLInputElement).value = activity.subject || '';
        (document.getElementById('activity-type') as HTMLSelectElement).value = activity.type || 'task';
        (document.getElementById('activity-description') as HTMLTextAreaElement).value = activity.body || '';
        if (activity.due_at) {
          (document.getElementById('activity-due-date') as HTMLInputElement).value = activity.due_at.replace('Z', '').slice(0, 16);
        }
      } else {
        title.textContent = 'Add Activity';
        (document.getElementById('activity-id') as HTMLInputElement).value = '';
        (document.getElementById('activity-form') as HTMLFormElement).reset();
      }

      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeModal() {
      const modal = document.getElementById('activity-modal')!;
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    (window as any).editActivity = async function(id: string) {
      try {
        const activity = await api.activities.get(auth.token!, id);
        openModal(activity);
      } catch (error) {
        console.error('Failed to load activity:', error);
      }
    };

    (window as any).toggleActivity = async function(id: string, currentStatus: string) {
      try {
        if (currentStatus === 'completed') {
          await api.activities.uncomplete(auth.token!, id);
        } else {
          await api.activities.complete(auth.token!, id);
        }
        loadActivities();
      } catch (error) {
        console.error('Failed to toggle activity:', error);
        alert('Failed to toggle activity');
      }
    };

    (window as any).deleteActivity = async function(id: string) {
      if (!confirm('Are you sure you want to delete this activity?')) return;

      try {
        await api.activities.delete(auth.token!, id);
        loadActivities();
      } catch (error) {
        console.error('Failed to delete activity:', error);
        alert('Failed to delete activity');
      }
    };

    document.addEventListener('DOMContentLoaded', () => {
      loadActivities();

      document.getElementById('add-activity-btn')?.addEventListener('click', () => openModal());
      document.getElementById('cancel-btn')?.addEventListener('click', closeModal);

      document.getElementById('activity-modal')?.addEventListener('click', (e) => {
        if (e.target === e.currentTarget) closeModal();
      });

      document.getElementById('type-filter')?.addEventListener('change', (e) => {
        currentType = (e.target as HTMLSelectElement).value;
        currentPage = 1;
        loadActivities();
      });

      document.getElementById('prev-btn')?.addEventListener('click', () => {
        if (currentPage > 1) {
          currentPage--;
          loadActivities();
        }
      });

      document.getElementById('next-btn')?.addEventListener('click', () => {
        currentPage++;
        loadActivities();
      });

      document.getElementById('activity-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const data: any = {
          title: (document.getElementById('activity-title') as HTMLInputElement).value,
          type: (document.getElementById('activity-type') as HTMLSelectElement).value,
        };

        const description = (document.getElementById('activity-description') as HTMLTextAreaElement).value;
        if (description) data.description = description;

        const dueDate = (document.getElementById('activity-due-date') as HTMLInputElement).value;
        if (dueDate) data.due_at = new Date(dueDate).toISOString();

        try {
          await api.activities.create(auth.token!, data);
          closeModal();
          loadActivities();
        } catch (error) {
          console.error('Failed to save activity:', error);
          alert('Failed to save activity');
        }
      });
    });
  </script>
</AppLayout>
