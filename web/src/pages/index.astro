---
export const prerender = false;
import '../styles/global.css';
import Logo from '../components/Logo.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>oscar CRM - The Future of Customer Relationships</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
</head>
<body class="bg-background text-on-background antialiased overflow-x-hidden">
  <!-- Ambient Background -->
  <div class="fixed inset-0 pointer-events-none">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-primary/10 via-background to-background"></div>
    <div class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-primary/20 rounded-full blur-[150px] animate-pulse-slow"></div>
    <div class="absolute bottom-0 right-1/4 w-[800px] h-[800px] bg-secondary/10 rounded-full blur-[200px] animate-pulse-slow" style="animation-delay: 1s"></div>
    <div class="absolute top-1/2 right-0 w-[400px] h-[400px] bg-tertiary/10 rounded-full blur-[120px] animate-pulse-slow" style="animation-delay: 2s"></div>
  </div>

  <!-- Grid Pattern -->
  <div class="fixed inset-0 pointer-events-none opacity-[0.03]">
    <div class="absolute inset-0" style="background-image: linear-gradient(rgba(210,187,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(210,187,255,0.3) 1px, transparent 1px); background-size: 80px 80px;"></div>
  </div>

  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-4">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
      <Logo link={true} />
      <div class="flex items-center gap-4">
        <a href="/login" class="px-4 py-2 text-sm font-medium text-on-surface-variant hover:text-on-surface transition-colors">Sign In</a>
        <a href="/register" class="px-5 py-2.5 bg-primary text-bg font-medium text-sm rounded-lg hover:bg-primary/90 transition-all hover:shadow-glow">
          Get Started
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center px-6 pt-20">
    <div class="max-w-6xl mx-auto text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-surface-raised/50 backdrop-blur-sm rounded-full border border-outline/20 mb-8 animate-fade-in">
        <span class="w-2 h-2 rounded-full bg-success animate-pulse"></span>
        <span class="text-body-sm text-on-surface-variant">Now in Public Beta</span>
      </div>

      <!-- Headline -->
      <h1 class="text-display-lg font-display text-on-surface leading-tight mb-6 animate-slide-up" style="animation-delay: 0.1s">
        The Future of<br/>
        <span class="text-gradient bg-gradient-to-r from-primary via-tertiary to-secondary bg-clip-text">Customer Relationships</span>
      </h1>

      <!-- Subheadline -->
      <p class="text-title-lg text-on-surface-variant max-w-2xl mx-auto mb-10 animate-slide-up" style="animation-delay: 0.2s">
        Transform how your team connects with customers. Oscar combines powerful automation with intuitive design to help you close deals faster.
      </p>

      <!-- CTA Buttons -->
      <div class="flex items-center justify-center gap-4 mb-16 animate-slide-up" style="animation-delay: 0.3s">
        <a href="/register" class="group relative px-8 py-4 bg-primary text-bg font-semibold rounded-xl overflow-hidden transition-all hover:shadow-glow-lg hover:scale-105">
          <span class="relative z-10 flex items-center gap-2">
            Start Free Trial
            <span class="material-symbols-outlined text-sm transition-transform group-hover:translate-x-1">arrow_forward</span>
          </span>
        </a>
        <a href="/demo" class="px-8 py-4 bg-surface-raised text-on-surface font-medium rounded-xl border border-outline/30 hover:border-outline/50 transition-all flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">play_circle</span>
          Watch Demo
        </a>
      </div>

      <!-- Floating Dashboard Preview -->
      <div class="relative max-w-5xl mx-auto animate-slide-up" style="animation-delay: 0.4s">
        <div class="absolute -inset-px bg-gradient-to-r from-primary/20 via-secondary/20 to-primary/20 rounded-2xl blur-xl"></div>

        <div class="relative bg-surface-base rounded-2xl border border-outline/20 overflow-hidden shadow-2xl">
          <div class="flex items-center gap-2 px-4 py-3 bg-surface-raised border-b border-outline/10">
            <div class="w-3 h-3 rounded-full bg-error/60"></div>
            <div class="w-3 h-3 rounded-full bg-warning/60"></div>
            <div class="w-3 h-3 rounded-full bg-success/60"></div>
            <div class="flex-1"></div>
            <div class="w-32 h-5 bg-surface-elevated rounded-full"></div>
          </div>

          <div class="p-6 bg-surface-dim">
            <div class="grid grid-cols-4 gap-4 mb-4">
              <div class="bg-surface-container-low p-4 rounded-xl">
                <div class="text-[10px] font-mono text-outline uppercase mb-2">Pipeline Value</div>
                <div class="text-2xl font-display font-bold text-primary">$4.2M</div>
                <div class="text-[10px] font-mono text-success mt-1">+12.4%</div>
              </div>
              <div class="bg-surface-container-low p-4 rounded-xl">
                <div class="text-[10px] font-mono text-outline uppercase mb-2">Active Deals</div>
                <div class="text-2xl font-display font-bold text-on-surface">142</div>
                <div class="text-[10px] font-mono text-outline mt-1">This month</div>
              </div>
              <div class="bg-surface-container-low p-4 rounded-xl">
                <div class="text-[10px] font-mono text-outline uppercase mb-2">Win Rate</div>
                <div class="text-2xl font-display font-bold text-secondary">68%</div>
                <div class="text-[10px] font-mono text-success mt-1">+5.2%</div>
              </div>
              <div class="bg-surface-container-low p-4 rounded-xl">
                <div class="text-[10px] font-mono text-outline uppercase mb-2">Avg Response</div>
                <div class="text-2xl font-display font-bold text-tertiary">1.2h</div>
                <div class="text-[10px] font-mono text-success mt-1">-40m</div>
              </div>
            </div>

            <div class="bg-surface-container-low p-4 rounded-xl">
              <div class="flex items-center justify-between mb-4">
                <div class="text-sm font-medium text-on-surface">Deal Close Rate</div>
                <div class="text-[10px] font-mono text-outline">Last 12 Months</div>
              </div>
              <div class="h-32 flex items-end gap-2">
                <div class="flex-1 bg-primary/20 rounded-t transition-all hover:bg-primary/30" style="height: 40%"></div>
                <div class="flex-1 bg-primary/20 rounded-t transition-all hover:bg-primary/30" style="height: 55%"></div>
                <div class="flex-1 bg-primary/20 rounded-t transition-all hover:bg-primary/30" style="height: 45%"></div>
                <div class="flex-1 bg-primary/20 rounded-t transition-all hover:bg-primary/30" style="height: 70%"></div>
                <div class="flex-1 bg-primary/20 rounded-t transition-all hover:bg-primary/30" style="height: 60%"></div>
                <div class="flex-1 bg-primary/20 rounded-t transition-all hover:bg-primary/30" style="height: 80%"></div>
                <div class="flex-1 bg-primary/20 rounded-t transition-all hover:bg-primary/30" style="height: 65%"></div>
                <div class="flex-1 bg-primary/20 rounded-t transition-all hover:bg-primary/30" style="height: 85%"></div>
                <div class="flex-1 bg-primary/30 rounded-t transition-all hover:bg-primary/40" style="height: 75%"></div>
                <div class="flex-1 bg-primary/30 rounded-t transition-all hover:bg-primary/40" style="height: 90%"></div>
                <div class="flex-1 bg-primary/40 rounded-t transition-all hover:bg-primary/50" style="height: 88%"></div>
                <div class="flex-1 bg-primary rounded-t shadow-glow" style="height: 95%"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Logos Section -->
  <section class="relative py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-center text-body-sm text-on-surface-variant mb-10 uppercase tracking-widest font-mono">Trusted by forward-thinking teams</p>
      <div class="flex items-center justify-center gap-12 flex-wrap opacity-60">
        <div class="text-2xl font-display font-bold text-on-surface-variant">Acme Corp</div>
        <div class="text-2xl font-display font-bold text-on-surface-variant">TechFlow</div>
        <div class="text-2xl font-display font-bold text-on-surface-variant">Quantum</div>
        <div class="text-2xl font-display font-bold text-on-surface-variant">Nexus</div>
        <div class="text-2xl font-display font-bold text-on-surface-variant">Zenith</div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="relative py-32 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-20">
        <h2 class="text-display-md font-display text-on-surface mb-4">Everything you need to scale</h2>
        <p class="text-title-md text-on-surface-variant max-w-2xl mx-auto">
          Powerful features designed for modern sales teams. From lead capture to deal closure, oscar has you covered.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="group relative p-6 bg-surface-container-low rounded-2xl border border-outline/10 hover:border-primary/30 transition-all hover:-translate-y-1">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-primary text-2xl">trending_up</span>
            </div>
            <h3 class="text-title-lg font-display font-semibold text-on-surface mb-2">Pipeline Management</h3>
            <p class="text-body-md text-on-surface-variant">
              Visualize your entire sales pipeline. Drag and drop deals between stages and track progress in real-time.
            </p>
          </div>
        </div>

        <div class="group relative p-6 bg-surface-container-low rounded-2xl border border-outline/10 hover:border-secondary/30 transition-all hover:-translate-y-1">
          <div class="absolute inset-0 bg-gradient-to-br from-secondary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-secondary text-2xl">group</span>
            </div>
            <h3 class="text-title-lg font-display font-semibold text-on-surface mb-2">Contact Management</h3>
            <p class="text-body-md text-on-surface-variant">
              Keep all your contacts organized with rich profiles, activity history, and custom fields.
            </p>
          </div>
        </div>

        <div class="group relative p-6 bg-surface-container-low rounded-2xl border border-outline/10 hover:border-tertiary/30 transition-all hover:-translate-y-1">
          <div class="absolute inset-0 bg-gradient-to-br from-tertiary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-xl bg-tertiary/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-tertiary text-2xl">bolt</span>
            </div>
            <h3 class="text-title-lg font-display font-semibold text-on-surface mb-2">Workflow Automation</h3>
            <p class="text-body-md text-on-surface-variant">
              Build powerful automations without code. Trigger actions based on any event in your CRM.
            </p>
          </div>
        </div>

        <div class="group relative p-6 bg-surface-container-low rounded-2xl border border-outline/10 hover:border-primary/30 transition-all hover:-translate-y-1">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-primary text-2xl">analytics</span>
            </div>
            <h3 class="text-title-lg font-display font-semibold text-on-surface mb-2">Advanced Analytics</h3>
            <p class="text-body-md text-on-surface-variant">
              Get actionable insights with custom dashboards and reports. Track every metric that matters.
            </p>
          </div>
        </div>

        <div class="group relative p-6 bg-surface-container-low rounded-2xl border border-outline/10 hover:border-secondary/30 transition-all hover:-translate-y-1">
          <div class="absolute inset-0 bg-gradient-to-br from-secondary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-secondary text-2xl">mail</span>
            </div>
            <h3 class="text-title-lg font-display font-semibold text-on-surface mb-2">Email Integration</h3>
            <p class="text-body-md text-on-surface-variant">
              Sync emails automatically. Track opens, clicks, and replies without leaving oscar.
            </p>
          </div>
        </div>

        <div class="group relative p-6 bg-surface-container-low rounded-2xl border border-outline/10 hover:border-tertiary/30 transition-all hover:-translate-y-1">
          <div class="absolute inset-0 bg-gradient-to-br from-tertiary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-xl bg-tertiary/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-tertiary text-2xl">schedule</span>
            </div>
            <h3 class="text-title-lg font-display font-semibold text-on-surface mb-2">Activity Tracking</h3>
            <p class="text-body-md text-on-surface-variant">
              Log calls, meetings, and notes automatically. Never miss a follow-up with smart reminders.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="relative py-32 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="relative p-12 bg-surface-container-low rounded-3xl border border-outline/20 overflow-hidden">
        <div class="absolute top-0 right-0 w-96 h-96 bg-primary/10 rounded-full blur-[100px]"></div>
        <div class="absolute bottom-0 left-0 w-96 h-96 bg-secondary/10 rounded-full blur-[100px]"></div>

        <div class="relative grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          <div>
            <div class="text-display-md font-display font-bold text-primary mb-2">10K+</div>
            <div class="text-body-sm text-on-surface-variant">Active Users</div>
          </div>
          <div>
            <div class="text-display-md font-display font-bold text-secondary mb-2">$500M+</div>
            <div class="text-body-sm text-on-surface-variant">Deals Tracked</div>
          </div>
          <div>
            <div class="text-display-md font-display font-bold text-tertiary mb-2">99.9%</div>
            <div class="text-body-sm text-on-surface-variant">Uptime SLA</div>
          </div>
          <div>
            <div class="text-display-md font-display font-bold text-on-surface mb-2">4.9/5</div>
            <div class="text-body-sm text-on-surface-variant">Customer Rating</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="relative py-32 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-display-md font-display text-on-surface mb-4">Loved by sales teams</h2>
        <p class="text-title-md text-on-surface-variant">See what our customers have to say</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="p-6 bg-surface-container-low rounded-2xl border border-outline/10">
          <div class="flex items-center gap-1 mb-4">
            <span class="material-symbols-outlined text-primary text-xl">star</span>
            <span class="material-symbols-outlined text-primary text-xl">star</span>
            <span class="material-symbols-outlined text-primary text-xl">star</span>
            <span class="material-symbols-outlined text-primary text-xl">star</span>
            <span class="material-symbols-outlined text-primary text-xl">star</span>
          </div>
          <p class="text-body-md text-on-surface mb-4">
            "oscar transformed how we manage our sales pipeline. The drag-and-drop interface is intuitive and the automation features save us hours every week."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center font-bold text-primary">SJ</div>
            <div>
              <div class="font-medium text-on-surface">Sarah Jenkins</div>
              <div class="text-body-sm text-on-surface-variant">VP of Sales, TechFlow</div>
            </div>
          </div>
        </div>

        <div class="p-6 bg-surface-container-low rounded-2xl border border-outline/10">
          <div class="flex items-center gap-1 mb-4">
            <span class="material-symbols-outlined text-primary text-xl">star</span>
            <span class="material-symbols-outlined text-primary text-xl">star</span>
            <span class="material-symbols-outlined text-primary text-xl">star</span>
            <span class="material-symbols-outlined text-primary text-xl">star</span>
            <span class="material-symbols-outlined text-primary text-xl">star</span>
          </div>
          <p class="text-body-md text-on-surface mb-4">
            "Finally, a CRM that doesn't feel like a chore to use. oscar's clean interface makes it easy for my entire team to stay on the same page."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-secondary/20 flex items-center justify-center font-bold text-secondary">MT</div>
            <div>
              <div class="font-medium text-on-surface">Marcus Thorne</div>
              <div class="text-body-sm text-on-surface-variant">CEO, Quantum Labs</div>
            </div>
          </div>
        </div>

        <div class="p-6 bg-surface-container-low rounded-2xl border border-outline/10">
          <div class="flex items-center gap-1 mb-4">
            <span class="material-symbols-outlined text-primary text-xl">star</span>
            <span class="material-symbols-outlined text-primary text-xl">star</span>
            <span class="material-symbols-outlined text-primary text-xl">star</span>
            <span class="material-symbols-outlined text-primary text-xl">star</span>
            <span class="material-symbols-outlined text-primary text-xl">star</span>
          </div>
          <p class="text-body-md text-on-surface mb-4">
            "The automation capabilities are incredible. We've cut our administrative work in half and now focus entirely on closing deals."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-tertiary/20 flex items-center justify-center font-bold text-tertiary">ER</div>
            <div>
              <div class="font-medium text-on-surface">Elena Rodriguez</div>
              <div class="text-body-sm text-on-surface-variant">Sales Director, Nexus</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative py-32 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <div class="relative p-16 bg-gradient-to-br from-primary-container/20 to-secondary-container/20 rounded-3xl border border-primary/20 overflow-hidden">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-primary/20 rounded-full blur-[120px]"></div>

        <div class="relative">
          <h2 class="text-display-md font-display text-on-surface mb-4">Ready to transform your sales?</h2>
          <p class="text-title-md text-on-surface-variant mb-10 max-w-xl mx-auto">
            Join thousands of teams using oscar to close more deals, faster. Start your free trial today—no credit card required.
          </p>

          <div class="flex items-center justify-center gap-4 flex-wrap">
            <a href="/register" class="group relative px-8 py-4 bg-primary text-bg font-semibold rounded-xl overflow-hidden transition-all hover:shadow-glow-lg hover:scale-105">
              Start Free Trial
              <span class="material-symbols-outlined text-sm ml-2 align-text-bottom">arrow_forward</span>
            </a>
            <a href="/demo" class="px-8 py-4 bg-surface-elevated/50 text-on-surface font-medium rounded-xl border border-outline/30 hover:border-outline/50 transition-all backdrop-blur-sm">
              Schedule Demo
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="relative py-16 px-6 border-t border-outline/10">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row items-center justify-between gap-8">
        <div class="flex items-center gap-3">
          <Logo size="sm"/>
        </div>

        <div class="flex items-center gap-8 text-body-sm text-on-surface-variant">
          <a href="/features" class="hover:text-on-surface transition-colors">Features</a>
          <a href="/pricing" class="hover:text-on-surface transition-colors">Pricing</a>
          <a href="/docs" class="hover:text-on-surface transition-colors">Documentation</a>
          <a href="/about" class="hover:text-on-surface transition-colors">About</a>
        </div>

        <div class="text-body-sm text-on-surface-variant">
          &copy; 2024 Oscar CRM. All rights reserved.
        </div>
      </div>
    </div>
  </footer>

  <style>
    @keyframes fade-in {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes slide-up {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes pulse-slow {
      0%, 100% { opacity: 0.5; transform: scale(1); }
      50% { opacity: 0.7; transform: scale(1.05); }
    }

    .animate-fade-in {
      animation: fade-in 0.6s ease-out forwards;
    }

    .animate-slide-up {
      opacity: 0;
      animation: slide-up 0.8s ease-out forwards;
    }

    .animate-pulse-slow {
      animation: pulse-slow 8s ease-in-out infinite;
    }

    .text-gradient {
      background: linear-gradient(135deg, #d2bbff 0%, #cebdff 50%, #b9c3ff 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .shadow-glow {
      box-shadow: 0 0 40px rgba(210, 187, 255, 0.4);
    }

    .shadow-glow-lg {
      box-shadow: 0 0 60px rgba(210, 187, 255, 0.5);
    }
  </style>
</body>
</html>
