---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Users">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Users</h1>
    <p class="text-gray-500">Manage team members and their roles</p>
  </div>

  <!-- Users Table -->
  <div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Roles</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Joined</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody id="users-table-body" class="divide-y divide-gray-200">
          <tr>
            <td colspan="6" class="px-6 py-12 text-center text-gray-400">
              <svg class="w-8 h-8 mx-auto mb-2 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              Loading users...
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Edit Roles Modal -->
  <div id="roles-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md mx-4">
      <div class="p-6 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Edit User Roles</h2>
        <p id="roles-modal-user" class="text-sm text-gray-500 mt-1"></p>
      </div>
      <form id="roles-form" class="p-6">
        <input type="hidden" id="edit-user-id">
        <div class="space-y-3">
          <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
            <input type="checkbox" name="role" value="Owner" class="w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500">
            <div>
              <p class="font-medium text-gray-900">Owner</p>
              <p class="text-xs text-gray-500">Full access to all features</p>
            </div>
          </label>
          <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
            <input type="checkbox" name="role" value="Admin" class="w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500">
            <div>
              <p class="font-medium text-gray-900">Admin</p>
              <p class="text-xs text-gray-500">Administrative access without billing</p>
            </div>
          </label>
          <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
            <input type="checkbox" name="role" value="Manager" class="w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500">
            <div>
              <p class="font-medium text-gray-900">Manager</p>
              <p class="text-xs text-gray-500">Team management with team-wide visibility</p>
            </div>
          </label>
          <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
            <input type="checkbox" name="role" value="Sales Rep" class="w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500">
            <div>
              <p class="font-medium text-gray-900">Sales Rep</p>
              <p class="text-xs text-gray-500">Standard sales representative access</p>
            </div>
          </label>
          <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
            <input type="checkbox" name="role" value="Read Only" class="w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500">
            <div>
              <p class="font-medium text-gray-900">Read Only</p>
              <p class="text-xs text-gray-500">View access to all records</p>
            </div>
          </label>
        </div>
        <div class="flex justify-end gap-3 pt-6">
          <button type="button" id="cancel-roles-btn" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700">Save Roles</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { auth, api } from '../lib/api';

    let availableRoles: any[] = [];

    async function loadUsers() {
      const token = auth.token;
      if (!token) {
        window.location.href = '/login';
        return;
      }

      try {
        const data = await api.users.list(token);
        const currentUser = auth.user;

        const tbody = document.getElementById('users-table-body')!;
        
        if (data.data && data.data.length > 0) {
          tbody.innerHTML = data.data.map((user: any) => `
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center mr-3">
                    <span class="text-primary-600 font-medium">${(user.first_name || '')[0] || ''}${(user.last_name || '')[0] || ''}</span>
                  </div>
                  <div>
                    <div class="text-sm font-medium text-gray-900">${user.first_name || ''} ${user.last_name || ''}</div>
                    ${user.id === currentUser?.id ? '<span class="text-xs text-primary-600">(You)</span>' : ''}
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${user.email || '-'}</td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex flex-wrap gap-1">
                  ${(user.roles || []).map((role: string) => `
                    <span class="px-2 py-1 text-xs font-medium rounded-full ${
                      role === 'Owner' ? 'bg-purple-100 text-purple-800' :
                      role === 'Admin' ? 'bg-red-100 text-red-800' :
                      role === 'Manager' ? 'bg-blue-100 text-blue-800' :
                      role === 'Sales Rep' ? 'bg-green-100 text-green-800' :
                      'bg-gray-100 text-gray-800'
                    }">${role}</span>
                  `).join('')}
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-2 py-1 text-xs font-medium rounded-full ${user.is_active ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}">
                  ${user.is_active ? 'Active' : 'Inactive'}
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${user.created_at ? new Date(user.created_at).toLocaleDateString() : '-'}</td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                <button onclick="editUserRoles('${user.id}', '${user.first_name} ${user.last_name}', '${user.roles?.join(',')}')" class="text-primary-600 hover:text-primary-900">Edit Roles</button>
              </td>
            </tr>
          `).join('');
        } else {
          tbody.innerHTML = `
            <tr>
              <td colspan="6" class="px-6 py-12 text-center text-gray-400">
                No users found.
              </td>
            </tr>
          `;
        }

        document.getElementById('total-count')!.textContent = data.meta?.total?.toString() || '0';

      } catch (error: any) {
        console.error('Failed to load users:', error);
        if (error.message?.includes('Unauthorized')) {
          auth.clear();
          window.location.href = '/login';
        }
      }
    }

    (window as any).editUserRoles = function(userId: string, userName: string, roles: string) {
      const modal = document.getElementById('roles-modal')!;
      const userDisplay = document.getElementById('roles-modal-user')!;
      
      (document.getElementById('edit-user-id') as HTMLInputElement).value = userId;
      userDisplay.textContent = userName;
      
      const checkboxes = document.querySelectorAll('#roles-form input[name="role"]');
      checkboxes.forEach((cb) => {
        (cb as HTMLInputElement).checked = false;
      });
      
      if (roles) {
        roles.split(',').forEach((role: string) => {
          const cb = document.querySelector(`#roles-form input[value="${role}"]`) as HTMLInputElement;
          if (cb) cb.checked = true;
        });
      }
      
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    };

    function closeModal() {
      const modal = document.getElementById('roles-modal')!;
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    document.addEventListener('DOMContentLoaded', () => {
      loadUsers();

      document.getElementById('cancel-roles-btn')?.addEventListener('click', closeModal);
      
      document.getElementById('roles-modal')?.addEventListener('click', (e) => {
        if (e.target === e.currentTarget) closeModal();
      });

      document.getElementById('roles-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const userId = (document.getElementById('edit-user-id') as HTMLInputElement).value;
        const selectedRoles: string[] = [];
        
        document.querySelectorAll('#roles-form input[name="role"]:checked').forEach((cb) => {
          selectedRoles.push((cb as HTMLInputElement).value);
        });

        if (selectedRoles.length === 0) {
          alert('Please select at least one role');
          return;
        }

        try {
          await api.users.updateRoles(auth.token!, userId, selectedRoles);
          closeModal();
          loadUsers();
        } catch (error: any) {
          console.error('Failed to update roles:', error);
          if (error.message?.includes('Forbidden')) {
            alert('You do not have permission to update user roles');
          } else {
            alert('Failed to update roles');
          }
        }
      });
    });
  </script>
</AppLayout>
