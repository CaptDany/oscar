---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Dashboard">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="text-gray-500">Overview of your sales pipeline</p>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-xl shadow-sm p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Total Deals</p>
          <p id="stats-deals" class="text-2xl font-bold text-gray-900">-</p>
        </div>
        <div class="w-12 h-12 rounded-lg bg-primary-100 flex items-center justify-center">
          <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>
      <p id="stats-deals-loading" class="text-sm text-gray-400 mt-2 hidden">Loading...</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Total Value</p>
          <p id="stats-value" class="text-2xl font-bold text-gray-900">-</p>
        </div>
        <div class="w-12 h-12 rounded-lg bg-green-100 flex items-center justify-center">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </div>
      </div>
      <p id="stats-value-loading" class="text-sm text-gray-400 mt-2 hidden">Loading...</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Persons</p>
          <p id="stats-persons" class="text-2xl font-bold text-gray-900">-</p>
        </div>
        <div class="w-12 h-12 rounded-lg bg-yellow-100 flex items-center justify-center">
          <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
      </div>
      <p id="stats-persons-loading" class="text-sm text-gray-400 mt-2 hidden">Loading...</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Companies</p>
          <p id="stats-companies" class="text-2xl font-bold text-gray-900">-</p>
        </div>
        <div class="w-12 h-12 rounded-lg bg-purple-100 flex items-center justify-center">
          <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
      </div>
      <p id="stats-companies-loading" class="text-sm text-gray-400 mt-2 hidden">Loading...</p>
    </div>
  </div>

  <!-- Recent Activity & Deals Pipeline -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Recent Activity -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900">Recent Activity</h2>
        <a href="/activities" class="text-sm text-primary-600 hover:text-primary-700">View all</a>
      </div>
      <div id="activities-list" class="space-y-4">
        <div class="text-center py-8 text-gray-400">
          <svg class="w-8 h-8 mx-auto mb-2 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <p>Loading activities...</p>
        </div>
      </div>
    </div>

    <!-- Recent Deals -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900">Recent Deals</h2>
        <a href="/deals" class="text-sm text-primary-600 hover:text-primary-700">View all</a>
      </div>
      <div id="deals-list" class="space-y-4">
        <div class="text-center py-8 text-gray-400">
          <svg class="w-8 h-8 mx-auto mb-2 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <p>Loading deals...</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Pipeline Overview -->
  <div class="mt-6 bg-white rounded-xl shadow-sm p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Pipeline Overview</h2>
      <a href="/pipeline" class="text-sm text-primary-600 hover:text-primary-700">View pipeline</a>
    </div>
    <div id="pipeline-overview" class="overflow-x-auto">
      <div class="text-center py-8 text-gray-400">
        <svg class="w-8 h-8 mx-auto mb-2 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <p>Loading pipeline...</p>
      </div>
    </div>
  </div>

  <script>
    import { auth, api } from '../lib/api';

    function formatCurrency(value: number): string {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      }).format(value);
    }

    function timeAgo(date: string): string {
      const now = new Date();
      const then = new Date(date);
      const seconds = Math.floor((now.getTime() - then.getTime()) / 1000);

      if (seconds < 60) return 'just now';
      if (seconds < 3600) return `${Math.floor(seconds / 60)}m ago`;
      if (seconds < 86400) return `${Math.floor(seconds / 3600)}h ago`;
      if (seconds < 604800) return `${Math.floor(seconds / 86400)}d ago`;
      return then.toLocaleDateString();
    }

(window as any).toggleActivity = async function(id: string, currentStatus: string) {
      const token = auth.token;
      if (!token) return;
      
      try {
        if (currentStatus === 'completed') {
          await api.activities.uncomplete(auth.token!, id);
        } else {
          await api.activities.complete(auth.token!, id);
        }
        loadDashboard();
      } catch (error) {
        console.error('Failed to toggle activity:', error);
      }
    };


    async function loadDashboard() {
      const token = auth.token;
      if (!token) {
        window.location.href = '/login';
        return;
      }

      // Show loading indicators
      document.getElementById('stats-deals-loading')?.classList.remove('hidden');
      document.getElementById('stats-value-loading')?.classList.remove('hidden');
      document.getElementById('stats-persons-loading')?.classList.remove('hidden');
      document.getElementById('stats-companies-loading')?.classList.remove('hidden');

      try {
        const [personsData, companiesData, dealsData, activitiesData] = await Promise.all([
          api.persons.list(token, { limit: 1 }),
          api.companies.list(token, { limit: 1, includeTotal: true }),
          api.deals.list(token, { limit: 100 }),
          api.activities.list(token, { limit: 5 }),
        ]);

        document.getElementById('stats-persons')!.textContent = personsData.meta?.total?.toString() || '0';
        document.getElementById('stats-companies')!.textContent = companiesData.meta?.total?.toString() || '0';
        document.getElementById('stats-deals')!.textContent = dealsData.meta?.total?.toString() || '0';
        document.getElementById('stats-persons-loading')?.classList.add('hidden');
        document.getElementById('stats-companies-loading')?.classList.add('hidden');
        document.getElementById('stats-deals-loading')?.classList.add('hidden');

        let totalValue = 0;
        dealsData.data?.forEach((deal: any) => {
          totalValue += deal.value || 0;
        });
        document.getElementById('stats-value')!.textContent = formatCurrency(totalValue);
        document.getElementById('stats-value-loading')?.classList.add('hidden');

        const activitiesList = document.getElementById('activities-list')!;
        if (activitiesData.data && activitiesData.data.length > 0) {
          activitiesList.innerHTML = activitiesData.data.map((activity: any) => `
            <div class="flex items-center gap-4 pb-4 border-b border-gray-100 last:border-0 cursor-pointer hover:bg-gray-50 -mx-2 px-2 rounded-lg transition-colors" onclick="window.location.href='/activities?highlight=${activity.id}'">
              <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center">
                <span class="text-primary-600 font-medium">${activity.type?.[0]?.toUpperCase() || 'A'}</span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm text-gray-900 truncate">${activity.subject || 'Activity'}</p>
                <p class="text-xs text-gray-500">${timeAgo(activity.due_at || activity.created_at)}</p>
              </div>
              <button onclick="event.stopPropagation(); toggleActivity('${activity.id}', '${activity.status}')" class="px-3 py-1 text-xs font-medium rounded-lg border ${activity.status === 'completed' ? 'bg-green-50 text-green-600 border-green-200 hover:bg-green-100' : 'bg-blue-50 text-blue-600 border-blue-200 hover:bg-blue-100'}">
                ${activity.status === 'completed' ? 'Completed' : 'Mark as completed'}
              </button>
            </div>
          `).join('');
        } else {
          activitiesList.innerHTML = '<p class="text-gray-400 text-center py-4">No recent activities</p>';
        }

        const dealsList = document.getElementById('deals-list')!;
        if (dealsData.data && dealsData.data.length > 0) {
          dealsList.innerHTML = dealsData.data.slice(0, 5).map((deal: any) => `
            <div class="flex items-center justify-between pb-4 border-b border-gray-100 last:border-0">
              <div>
                <p class="text-sm font-medium text-gray-900">${deal.title || 'Untitled Deal'}</p>
                <p class="text-xs text-gray-500">${deal.stage_name || 'No stage'}</p>
              </div>
              <div class="text-right">
                <p class="text-sm font-medium text-gray-900">${formatCurrency(deal.value || 0)}</p>
                <p class="text-xs text-gray-500">${deal.status || 'open'}</p>
              </div>
            </div>
          `).join('');
        } else {
          dealsList.innerHTML = '<p class="text-gray-400 text-center py-4">No deals found</p>';
        }

        try {
          const pipelinesData = await api.pipelines.list(token);
          const pipelineOverview = document.getElementById('pipeline-overview')!;

          if (pipelinesData.data && pipelinesData.data.length > 0) {
            const pipeline = pipelinesData.data[0];
            const stagesData = await api.pipelines.getStages(token, pipeline.id);

            if (stagesData && stagesData.length > 0) {
              pipelineOverview.innerHTML = `
                <div class="flex gap-4 overflow-x-auto pb-2">
                  ${stagesData.map((stage: any) => {
                    const stageDeals = dealsData.data?.filter((d: any) => d.stage_id === stage.id) || [];
                    const stageValue = stageDeals.reduce((sum: number, d: any) => sum + (d.value || 0), 0);
                    return `
                      <div class="flex-shrink-0 w-64 p-4 bg-gray-50 rounded-lg">
                        <div class="flex items-center justify-between mb-3">
                          <h3 class="font-medium text-gray-900">${stage.name}</h3>
                          <span class="text-xs bg-gray-200 text-gray-600 px-2 py-1 rounded">${stageDeals.length}</span>
                        </div>
                        <p class="text-lg font-semibold text-primary-600">${formatCurrency(stageValue)}</p>
                        <div class="mt-2 space-y-1">
                          ${stageDeals.slice(0, 3).map((deal: any) => `
                            <div class="text-xs text-gray-600 truncate">${deal.title || 'Untitled'}</div>
                          `).join('')}
                          ${stageDeals.length > 3 ? `<div class="text-xs text-gray-400">+${stageDeals.length - 3} more</div>` : ''}
                        </div>
                      </div>
                    `;
                  }).join('')}
                </div>
              `;
            } else {
              pipelineOverview.innerHTML = '<p class="text-gray-400 text-center py-4">No stages found</p>';
            }
          } else {
            pipelineOverview.innerHTML = '<p class="text-gray-400 text-center py-4">No pipelines found</p>';
          }
        } catch {}

      } catch (error: any) {
        console.error('Failed to load dashboard:', error);
        if (error.message?.includes('Unauthorized') || error.message?.includes('401')) {
          auth.clear();
          window.location.href = '/login';
        }
      }
    }

    document.addEventListener('DOMContentLoaded', loadDashboard);
  </script>
</AppLayout>
