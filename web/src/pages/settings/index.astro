  async function getPresignedURL(assetType: string, filename: string) {
    const token = getToken();
    const res = await fetch('/api/v1/upload/branding/presigned', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
      body: JSON.stringify({ asset_type: assetType, filename })
    });
    if (!res.ok) throw new Error('Failed to get presigned URL');
    return res.json();
  }

  async function confirmUpload(objectKey: string, assetType: string) {
    const token = getToken();
    const res = await fetch('/api/v1/upload/branding/confirm', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
      body: JSON.stringify({ object_key: objectKey, asset_type: assetType })
    });
    if (!res.ok) throw new Error('Failed to confirm upload');
    return res.json();
  }

  function getToken(): string | null {
    const stored = localStorage.getItem('oscar_auth');
    if (stored) { const { token } = JSON.parse(stored); if (token) return token; }
    const cookies = Object.fromEntries(document.cookie.split('; ').map(c => c.split('=')));
    return cookies['oscar_token'] || null;
  }

  function getCachedBrandingURL(objectKey: string): string | null {
    return sessionStorage.getItem('branding_url_' + objectKey);
  }

  function cacheBrandingURL(objectKey: string, url: string): void {
    sessionStorage.setItem('branding_url_' + objectKey, url);
  }

  async function loadSettings() {
    const token = getToken();
    if (!token) return;
    try {
      const res = await fetch('/api/v1/settings', { headers: { Authorization: `Bearer ${token}` } });
      const { data } = await res.json();
      if (data) {
        if (data.primary_color) {
          const input = document.getElementById('primary-color') as HTMLInputElement;
          if (input) input.value = data.primary_color;
          previewConfig.primaryColor = data.primary_color;
        }
        if (data.secondary_color) {
          const input = document.getElementById('secondary-color') as HTMLInputElement;
          if (input) input.value = data.secondary_color;
          previewConfig.secondaryColor = data.secondary_color;
        }
        if (data.accent_color) {
          const input = document.getElementById('accent-color') as HTMLInputElement;
          if (input) input.value = data.accent_color;
          previewConfig.accentColor = data.accent_color;
        }
        if (data.font_family) {
          const select = document.getElementById('headline-font') as HTMLSelectElement;
          if (select) select.value = data.font_family;
          previewConfig.headlineFont = data.font_family;
        }
        if (data.mono_font) {
          const select = document.getElementById('mono-font') as HTMLSelectElement;
          if (select) select.value = data.mono_font;
          previewConfig.monoFont = data.mono_font;
        }
        updatePreview();
        selectColorType('primary');
        const secondaryPreview = document.getElementById('secondary-color-preview');
        if (secondaryPreview) secondaryPreview.style.backgroundColor = previewConfig.secondaryColor;
        const accentPreview = document.getElementById('accent-color-preview');
        if (accentPreview) accentPreview.style.backgroundColor = previewConfig.accentColor;
      }
    } catch (err) { console.error('Failed to load settings:', err); }
  }

  async function saveSettings() {
    const token = getToken();
    if (!token) return;
    const primaryColor = (document.getElementById('primary-color') as HTMLInputElement)?.value;
    const secondaryColor = (document.getElementById('secondary-color') as HTMLInputElement)?.value;
    const accentColor = (document.getElementById('accent-color') as HTMLInputElement)?.value;
    const fontFamily = (document.getElementById('headline-font') as HTMLSelectElement)?.value;
    const monoFont = (document.getElementById('mono-font') as HTMLSelectElement)?.value;
    try {
      const res = await fetch('/api/v1/settings', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
        body: JSON.stringify({
          primary_color: primaryColor,
          secondary_color: secondaryColor,
          accent_color: accentColor,
          font_family: fontFamily,
          mono_font: monoFont,
        })
      });
      if (res.ok) { alert('Settings saved!'); }
      else { const error = await res.json(); alert('Failed: ' + (error.error?.message || 'Unknown')); }
    } catch (err) { console.error(err); }
  }

  document.addEventListener('DOMContentLoaded', () => {
    initPreviewListeners();
    selectColorType('primary');
    loadSettings();
  });
</script>

