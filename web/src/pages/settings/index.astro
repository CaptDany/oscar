---
export const prerender = false;
import AppLayout from '../../layouts/AppLayout.astro';

const { user } = Astro.locals;
if (!user) return Astro.redirect('/login');

const isAdmin = user.roles?.includes('Owner') || user.roles?.includes('Admin');
---

<head>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bitter:wght@400;500;600;700&family=Cousine:wght@400;700&family=Courier+Prime:wght@400;700&family=Fira+Code:wght@400;500;600;700&family=Fira+Sans:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&family=Inconsolata:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Lato:wght@400;700&family=Merriweather:wght@400;700&family=Montserrat:wght@400;500;600;700&family=Nunito:wght@400;500;600;700&family=Open+Sans:wght@400;500;600;700&family=Oswald:wght@400;500;600;700&family=Overpass+Mono:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600;700&family=Poppins:wght@400;500;600;700&family=Raleway:wght@400;500;600;700&family=Roboto+Mono:wght@400;500;600;700&family=Roboto+Slab:wght@400;500;600;700&family=Rubik:wght@400;500;600;700&family=Source+Code+Pro:wght@400;500;600;700&family=Source+Sans+Pro:wght@400;600;700&family=Space+Mono:wght@400;700&family=Space+Grotesk:wght@400;500;600;700&family=Ubuntu:wght@400;500;600;700&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<AppLayout title="Settings">
  <main class="ml-[220px] pt-10 px-8 pb-20">
    <div class="max-w-7xl mx-auto">
      <div class="mb-12">
        <h2 class="text-4xl font-headline font-bold text-on-background tracking-tight mb-2">Settings</h2>
        <p class="text-on-surface-variant font-mono text-sm max-w-2xl uppercase tracking-wider">Manage your Oscar CRM configuration</p>
      </div>

      <!-- Settings Navigation -->
      <div class="flex gap-6 mb-8 border-b border-outline-variant/20 pb-4">
        <a href="/settings" class="text-primary border-b-2 border-primary pb-2 font-mono text-sm uppercase tracking-widest">Branding</a>
        <a href="/settings/users" class="text-gray-500 hover:text-white transition-colors font-mono text-sm uppercase tracking-widest">Users</a>
        <a href="/settings/security" class="text-gray-500 hover:text-white transition-colors font-mono text-sm uppercase tracking-widest">Security</a>
        <a href="/settings/pipelines" class="text-gray-500 hover:text-white transition-colors font-mono text-sm uppercase tracking-widest">Pipelines</a>
        <a href="/settings/profile" class="text-gray-500 hover:text-white transition-colors font-mono text-sm uppercase tracking-widest">My Profile</a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <!-- Left Column: Settings Form -->
        <div class="lg:col-span-5 flex flex-col gap-8">
          <!-- Color Picker Section -->
          <section class="bg-surface-container-low p-6 rounded-lg">
            <div class="flex items-center justify-between mb-6">
              <h3 class="font-headline text-lg font-semibold flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">palette</span>
                Accent Architecture
              </h3>
            </div>
            <div class="space-y-4">
              <div class="grid grid-cols-3 gap-2">
                <button class="color-type-btn aspect-square rounded border-2 border-transparent hover:border-outline-variant transition-colors relative" data-type="primary">
                  <span class="absolute inset-1 rounded"></span>
                </button>
                <button class="color-type-btn aspect-square rounded border-2 border-transparent hover:border-outline-variant transition-colors relative" data-type="secondary">
                  <span class="absolute inset-1 rounded"></span>
                </button>
                <button class="color-type-btn aspect-square rounded border-2 border-transparent hover:border-outline-variant transition-colors relative" data-type="accent">
                  <span class="absolute inset-1 rounded"></span>
                </button>
              </div>
              <div id="color-swatches" class="grid grid-cols-5 gap-3">
                <button class="color-swatch aspect-square bg-[#d2bbff] rounded border-2 border-transparent hover:border-white/50 transition-transform" data-color="#d2bbff"></button>
                <button class="color-swatch aspect-square bg-[#7c3aed] rounded border-2 border-transparent hover:scale-105 transition-transform" data-color="#7c3aed"></button>
                <button class="color-swatch aspect-square bg-[#0044fe] rounded border-2 border-transparent hover:scale-105 transition-transform" data-color="#0044fe"></button>
                <button class="color-swatch aspect-square bg-[#cebdff] rounded border-2 border-transparent hover:scale-105 transition-transform" data-color="#cebdff"></button>
                <button class="color-swatch aspect-square bg-[#b9c3ff] rounded border-2 border-transparent hover:scale-105 transition-transform" data-color="#b9c3ff"></button>
                <button class="color-swatch aspect-square bg-[#6366f1] rounded border-2 border-transparent hover:scale-105 transition-transform" data-color="#6366f1"></button>
                <button class="color-swatch aspect-square bg-[#8b5cf6] rounded border-2 border-transparent hover:scale-105 transition-transform" data-color="#8b5cf6"></button>
                <button class="color-swatch aspect-square bg-[#06b6d4] rounded border-2 border-transparent hover:scale-105 transition-transform" data-color="#06b6d4"></button>
                <button class="color-swatch aspect-square bg-[#10b981] rounded border-2 border-transparent hover:scale-105 transition-transform" data-color="#10b981"></button>
              </div>
            </div>
          </section>

          <!-- Logo Upload Section -->
          <section class="bg-surface-container-low p-6 rounded-lg">
            <div class="flex items-center justify-between mb-6">
              <h3 class="font-headline text-lg font-semibold flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">token</span>
                Brand Assets
              </h3>
              <span class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">SVG Only</span>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="text-[10px] font-mono text-slate-500 uppercase tracking-widest mb-2 block">Light Logo</label>
                <div id="logo-light-upload-area" class="border-2 border-dashed border-outline-variant rounded-xl p-4 flex flex-col items-center justify-center gap-2 bg-surface-container-lowest hover:bg-surface-container transition-all group cursor-pointer aspect-square">
                  <div class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-slate-500 group-hover:text-primary transition-colors">
                    <span class="material-symbols-outlined text-xl">upload_file</span>
                  </div>
                  <p class="text-xs text-slate-500">Drop SVG</p>
                  <input type="file" id="logo-light-input" class="hidden" accept=".svg" />
                </div>
                <div id="logo-light-preview" class="hidden mt-2 p-2 bg-surface-container rounded-lg flex items-center gap-2">
                  <div id="logo-light-preview-img" class="w-8 h-8 bg-primary-container rounded flex items-center justify-center">
                    <span class="text-white font-bold text-xs">O</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p id="logo-light-name" class="text-xs truncate">logo.svg</p>
                  </div>
                  <button onclick="removeLogoLight()" class="p-1 hover:bg-surface-container-high rounded text-gray-400">
                    <span class="material-symbols-outlined text-sm">delete</span>
                  </button>
                </div>
              </div>
              <div>
                <label class="text-[10px] font-mono text-slate-500 uppercase tracking-widest mb-2 block">Dark Logo</label>
                <div id="logo-dark-upload-area" class="border-2 border-dashed border-outline-variant rounded-xl p-4 flex flex-col items-center justify-center gap-2 bg-surface-container-lowest hover:bg-surface-container transition-all group cursor-pointer aspect-square">
                  <div class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-slate-500 group-hover:text-primary transition-colors">
                    <span class="material-symbols-outlined text-xl">upload_file</span>
                  </div>
                  <p class="text-xs text-slate-500">Drop SVG</p>
                  <input type="file" id="logo-dark-input" class="hidden" accept=".svg" />
                </div>
                <div id="logo-dark-preview" class="hidden mt-2 p-2 bg-surface-container rounded-lg flex items-center gap-2">
                  <div id="logo-dark-preview-img" class="w-8 h-8 bg-surface-container-highest rounded flex items-center justify-center">
                    <span class="text-on-surface font-bold text-xs">O</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p id="logo-dark-name" class="text-xs truncate">logo.svg</p>
                  </div>
                  <button onclick="removeLogoDark()" class="p-1 hover:bg-surface-container-high rounded text-gray-400">
                    <span class="material-symbols-outlined text-sm">delete</span>
                  </button>
                </div>
              </div>
              <div>
                <label class="text-[10px] font-mono text-slate-500 uppercase tracking-widest mb-2 block">Light Favicon</label>
                <div id="favicon-light-upload-area" class="border-2 border-dashed border-outline-variant rounded-xl p-4 flex flex-col items-center justify-center gap-2 bg-surface-container-lowest hover:bg-surface-container transition-all group cursor-pointer aspect-square">
                  <div class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-slate-500 group-hover:text-primary transition-colors">
                    <span class="material-symbols-outlined text-xl">upload_file</span>
                  </div>
                  <p class="text-xs text-slate-500">Drop SVG</p>
                  <input type="file" id="favicon-light-input" class="hidden" accept=".svg" />
                </div>
                <div id="favicon-light-preview" class="hidden mt-2 p-2 bg-surface-container rounded-lg flex items-center gap-2">
                  <div id="favicon-light-preview-img" class="w-8 h-8 bg-primary-container rounded flex items-center justify-center">
                    <span class="text-white font-bold text-xs">O</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p id="favicon-light-name" class="text-xs truncate">favicon.svg</p>
                  </div>
                  <button onclick="removeFaviconLight()" class="p-1 hover:bg-surface-container-high rounded text-gray-400">
                    <span class="material-symbols-outlined text-sm">delete</span>
                  </button>
                </div>
              </div>
              <div>
                <label class="text-[10px] font-mono text-slate-500 uppercase tracking-widest mb-2 block">Dark Favicon</label>
                <div id="favicon-dark-upload-area" class="border-2 border-dashed border-outline-variant rounded-xl p-4 flex flex-col items-center justify-center gap-2 bg-surface-container-lowest hover:bg-surface-container transition-all group cursor-pointer aspect-square">
                  <div class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-slate-500 group-hover:text-primary transition-colors">
                    <span class="material-symbols-outlined text-xl">upload_file</span>
                  </div>
                  <p class="text-xs text-slate-500">Drop SVG</p>
                  <input type="file" id="favicon-dark-input" class="hidden" accept=".svg" />
                </div>
                <div id="favicon-dark-preview" class="hidden mt-2 p-2 bg-surface-container rounded-lg flex items-center gap-2">
                  <div id="favicon-dark-preview-img" class="w-8 h-8 bg-surface-container-highest rounded flex items-center justify-center">
                    <span class="text-on-surface font-bold text-xs">O</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p id="favicon-dark-name" class="text-xs truncate">favicon.svg</p>
                  </div>
                  <button onclick="removeFaviconDark()" class="p-1 hover:bg-surface-container-high rounded text-gray-400">
                    <span class="material-symbols-outlined text-sm">delete</span>
                  </button>
                </div>
              </div>
            </div>
          </section>

          <!-- Font Selector -->
          <section class="bg-surface-container-low p-6 rounded-lg">
            <div class="flex items-center justify-between mb-6">
              <h3 class="font-headline text-lg font-semibold flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">format_size</span>
                Typography Matrix
              </h3>
            </div>
            <div class="space-y-4">
              <div class="flex flex-col gap-1">
                <label class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">Headline Font</label>
                <select id="headline-font" class="bg-surface-container-highest border-none focus:ring-1 focus:ring-primary text-sm p-3 rounded-lg">
                  <option value="Space Grotesk">Space Grotesk</option>
                  <option value="Inter">Inter</option>
                  <option value="Poppins">Poppins</option>
                  <option value="Playfair Display">Playfair Display</option>
                  <option value="Montserrat">Montserrat</option>
                  <option value="Roboto Slab">Roboto Slab</option>
                  <option value="Oswald">Oswald</option>
                  <option value="Raleway">Raleway</option>
                  <option value="Merriweather">Merriweather</option>
                  <option value="Nunito">Nunito</option>
                  <option value="Open Sans">Open Sans</option>
                  <option value="Lato">Lato</option>
                  <option value="Source Sans Pro">Source Sans Pro</option>
                  <option value="Ubuntu">Ubuntu</option>
                  <option value="Fira Sans">Fira Sans</option>
                  <option value="Work Sans">Work Sans</option>
                  <option value="Rubik">Rubik</option>
                  <option value="Bitter">Bitter</option>
                </select>
              </div>
              <div class="flex flex-col gap-1">
                <label class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">Mono Font</label>
                <select id="mono-font" class="bg-surface-container-highest border-none focus:ring-1 focus:ring-primary text-sm p-3 rounded-lg font-mono">
                  <option value="Geist Mono">Geist Mono</option>
                  <option value="Fira Code">Fira Code</option>
                  <option value="JetBrains Mono">JetBrains Mono</option>
                  <option value="Source Code Pro">Source Code Pro</option>
                  <option value="Roboto Mono">Roboto Mono</option>
                  <option value="Ubuntu Mono">Ubuntu Mono</option>
                  <option value="IBM Plex Mono">IBM Plex Mono</option>
                  <option value="Inconsolata">Inconsolata</option>
                  <option value="Cousine">Cousine</option>
                  <option value="Courier Prime">Courier Prime</option>
                  <option value="Overpass Mono">Overpass Mono</option>
                  <option value="Space Mono">Space Mono</option>
                </select>
              </div>
              <div class="flex flex-col gap-1">
                <label class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">Secondary Color</label>
                <div class="flex items-center gap-2">
                  <input id="secondary-color" class="flex-1 bg-surface-container-highest border-none rounded-lg px-3 py-2 text-sm font-mono" type="text" placeholder="#7c3aed"/>
                  <div id="secondary-color-preview" class="w-8 h-8 rounded bg-[#7c3aed] border border-outline"></div>
                </div>
              </div>
              <div class="flex flex-col gap-1">
                <label class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">Accent Color</label>
                <div class="flex items-center gap-2">
                  <input id="accent-color" class="flex-1 bg-surface-container-highest border-none rounded-lg px-3 py-2 text-sm font-mono" type="text" placeholder="#0044fe"/>
                  <div id="accent-color-preview" class="w-8 h-8 rounded bg-[#0044fe] border border-outline"></div>
                </div>
              </div>
            </div>
          </section>

          <!-- Organization -->
          <section class="bg-surface-container-low p-6 rounded-lg">
            <div class="flex items-center justify-between mb-6">
              <h3 class="font-headline text-lg font-semibold flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">business</span>
                Organization
              </h3>
            </div>
            <div class="space-y-4">
              <div>
                <label class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">Tenant Name</label>
                <input id="tenant-name" class="w-full bg-surface-container-highest border-none focus:ring-1 focus:ring-primary text-sm p-3 rounded-lg mt-2" type="text" placeholder="My Company"/>
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">Currency</label>
                  <select id="currency" class="w-full bg-surface-container-highest border-none focus:ring-1 focus:ring-primary text-sm p-3 rounded-lg mt-2">
                    <option value="USD">USD ($)</option>
                    <option value="EUR">EUR (€)</option>
                    <option value="GBP">GBP (£)</option>
                    <option value="CAD">CAD ($)</option>
                    <option value="MXN">MXN ($)</option>
                  </select>
                </div>
                <div>
                  <label class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">Timezone</label>
                  <select id="timezone" class="w-full bg-surface-container-highest border-none focus:ring-1 focus:ring-primary text-sm p-3 rounded-lg mt-2">
                    <option value="America/New_York">Eastern (ET)</option>
                    <option value="America/Chicago">Central (CT)</option>
                    <option value="America/Denver">Mountain (MT)</option>
                    <option value="America/Los_Angeles">Pacific (PT)</option>
                    <option value="America/Mexico_City">Mexico City</option>
                    <option value="Europe/London">London</option>
                    <option value="Europe/Paris">Paris</option>
                  </select>
                </div>
              </div>
            </div>
          </section>

          {isAdmin && (
            <button onclick="saveSettings()" class="w-full py-3 bg-primary-container text-white font-mono rounded-lg hover:opacity-90 transition-opacity shadow-lg shadow-primary-container/20">
              Save Changes
            </button>
          )}
        </div>

        <!-- Right Column: Live Preview -->
        <div class="lg:col-span-7 sticky top-24">
          <div class="relative">
            <div class="absolute -top-3 left-6 bg-primary-container text-on-primary-container px-3 py-1 rounded-full text-[10px] font-mono uppercase font-bold tracking-tighter z-10 shadow-lg shadow-primary-container/20">
              Realtime Canvas Preview
            </div>
            <div class="bg-surface-container rounded-xl overflow-hidden shadow-2xl border border-outline-variant/10">
              <div class="flex h-[600px] bg-background">
                <div id="preview-sidebar" class="w-16 h-full bg-surface-container-low flex flex-col items-center py-6 gap-6">
                  <div id="preview-logo" class="w-8 h-8 rounded bg-primary-container flex items-center justify-center">
                    <span class="material-symbols-outlined text-white text-sm" style="font-variation-settings: 'FILL' 1;">architecture</span>
                  </div>
                  <div class="w-8 h-8 rounded-lg flex items-center justify-center text-primary border-r-2 border-primary">
                    <span class="material-symbols-outlined text-sm">grid_view</span>
                  </div>
                  <div class="w-8 h-8 flex items-center justify-center text-slate-600"><span class="material-symbols-outlined text-sm">dataset</span></div>
                  <div class="w-8 h-8 flex items-center justify-center text-slate-600"><span class="material-symbols-outlined text-sm">settings_input_component</span></div>
                </div>
                <div class="flex-1 p-8 space-y-8 overflow-hidden">
                  <div class="flex items-center justify-between border-b border-outline-variant/10 pb-4">
                    <div id="preview-nav-text" class="h-4 w-32 bg-surface-container-highest rounded-full font-mono text-[8px] text-slate-500"></div>
                    <div class="flex gap-3">
                      <div class="h-8 w-8 bg-surface-container-highest rounded"></div>
                      <div id="preview-button" class="h-8 w-24 text-on-primary rounded flex items-center justify-center text-[10px] font-bold">COMMIT CHANGES</div>
                    </div>
                  </div>
                  <div class="grid grid-cols-2 gap-4">
                    <div class="bg-surface-container-low p-4 rounded-lg h-40 flex flex-col justify-between">
                      <div class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">Active Node</div>
                      <div id="preview-primary-text" class="text-2xl font-headline font-bold">02.X-STABLE</div>
                      <div class="h-1 w-full bg-surface-container-highest rounded-full overflow-hidden">
                        <div id="preview-progress-bar" class="h-full w-2/3"></div>
                      </div>
                    </div>
                    <div class="bg-surface-container-low p-4 rounded-lg h-40">
                      <div class="flex justify-between items-start mb-4">
                        <div class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">Traffic flow</div>
                        <span id="preview-icon" class="material-symbols-outlined text-xs">show_chart</span>
                      </div>
                      <div class="space-y-2">
                        <div class="h-2 w-full bg-surface-container-highest rounded-full"></div>
                        <div class="h-2 w-3/4 bg-surface-container-highest rounded-full opacity-50"></div>
                        <div class="h-2 w-1/2 bg-surface-container-highest rounded-full opacity-30"></div>
                      </div>
                    </div>
                    <div id="preview-card" class="col-span-2 p-6 rounded-lg h-48 border relative overflow-hidden">
                      <div class="relative z-10">
                        <h4 id="preview-headline-font" class="text-xl font-headline font-bold mb-2">Oscar UI Ready</h4>
                        <p id="preview-body-font" class="text-xs max-w-sm mb-6">Component libraries successfully synchronized with primary brand tokens.</p>
                        <button id="preview-cta-button" class="px-4 py-2 rounded text-[10px] font-bold shadow-lg hover:scale-95 transition-transform">INITIALIZE DEPLOY</button>
                      </div>
                      <div class="absolute -right-8 -bottom-8 opacity-10">
                        <span class="material-symbols-outlined text-[160px]">terminal</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="absolute -right-4 top-1/2 -translate-y-1/2 flex flex-col gap-32">
              <div class="bg-surface-container-highest border border-outline-variant p-2 rounded flex items-center gap-2 shadow-xl whitespace-nowrap">
                <span id="preview-color-dot" class="w-3 h-3 rounded-full animate-pulse"></span>
                <span id="preview-color-label" class="text-[9px] font-mono uppercase tracking-widest">Primary: #D2BBFF</span>
              </div>
              <div class="bg-surface-container-highest border border-outline-variant p-2 rounded flex items-center gap-2 shadow-xl whitespace-nowrap">
                <span class="w-3 h-3 rounded-full bg-surface-container-low"></span>
                <span class="text-[9px] font-mono uppercase tracking-widest">Base: #131315</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</AppLayout>

<script>
  let selectedColorType = 'primary';
  let faviconLightFile: File | null = null;
  let faviconLightPreviewUrl: string | null = null;
  let faviconDarkFile: File | null = null;
  let faviconDarkPreviewUrl: string | null = null;

  const previewConfig = {
    primaryColor: '#D2BBFF',
    secondaryColor: '#7c3aed',
    accentColor: '#0044fe',
    headlineFont: 'Space Grotesk',
    monoFont: 'Geist Mono'
  };

  function initPreviewListeners() {
    document.getElementById('primary-color')?.addEventListener('input', (e) => {
      const color = (e.target as HTMLInputElement).value;
      if (color.match(/^#[0-9A-Fa-f]{6}$/)) {
        previewConfig.primaryColor = color;
        updatePreview();
        updateColorSwatches();
      }
    });

    document.getElementById('secondary-color')?.addEventListener('input', (e) => {
      const color = (e.target as HTMLInputElement).value;
      if (color.match(/^#[0-9A-Fa-f]{6}$/)) {
        previewConfig.secondaryColor = color;
        updatePreview();
      }
    });

    document.getElementById('accent-color')?.addEventListener('input', (e) => {
      const color = (e.target as HTMLInputElement).value;
      if (color.match(/^#[0-9A-Fa-f]{6}$/)) {
        previewConfig.accentColor = color;
        updatePreview();
      }
    });

    document.getElementById('headline-font')?.addEventListener('change', (e) => {
      const font = (e.target as HTMLSelectElement).value;
      previewConfig.headlineFont = font;
      updatePreview();
    });

    document.getElementById('mono-font')?.addEventListener('change', (e) => {
      const font = (e.target as HTMLSelectElement).value;
      previewConfig.monoFont = font;
      updatePreview();
    });
  }

  function updatePreview() {
    const { primaryColor, secondaryColor, accentColor, headlineFont, monoFont } = previewConfig;

    const colorDot = document.getElementById('preview-color-dot');
    const colorLabel = document.getElementById('preview-color-label');
    const primaryText = document.getElementById('preview-primary-text');
    const headlineText = document.getElementById('preview-headline-font');
    const bodyText = document.getElementById('preview-body-font');
    const navText = document.getElementById('preview-nav-text');
    const sidebar = document.getElementById('preview-sidebar');
    const logo = document.getElementById('preview-logo');
    const button = document.getElementById('preview-button');
    const ctaButton = document.getElementById('preview-cta-button');
    const progressBar = document.getElementById('preview-progress-bar');
    const icon = document.getElementById('preview-icon');
    const card = document.getElementById('preview-card');

    if (colorDot) colorDot.style.backgroundColor = primaryColor;
    if (colorLabel) colorLabel.textContent = `Primary: ${primaryColor}`;
    if (primaryText) primaryText.style.color = primaryColor;
    if (headlineText) {
      headlineText.style.fontFamily = `'${headlineFont}', sans-serif`;
      headlineText.style.color = primaryColor;
    }
    if (bodyText) bodyText.style.fontFamily = `'${monoFont}', monospace`;
    if (navText) navText.style.fontFamily = `'${monoFont}', monospace`;
    if (sidebar) sidebar.style.borderRight = `2px solid ${primaryColor}`;
    if (logo) {
      logo.style.backgroundColor = primaryColor;
      logo.style.border = `2px solid ${primaryColor}`;
    }
    if (button) {
      button.style.backgroundColor = primaryColor;
      button.style.border = `2px solid ${primaryColor}`;
    }
    if (ctaButton) {
      ctaButton.style.backgroundColor = secondaryColor;
      ctaButton.style.color = '#ffffff';
      ctaButton.style.boxShadow = `0 10px 15px -3px ${secondaryColor}40`;
    }
    if (progressBar) progressBar.style.backgroundColor = primaryColor;
    if (icon) icon.style.color = accentColor;
    if (card) {
      card.style.background = `linear-gradient(135deg, ${primaryColor}20, #131315)`;
      card.style.borderColor = `${primaryColor}33`;
    }

    const secondaryPreview = document.getElementById('secondary-color-preview');
    if (secondaryPreview) secondaryPreview.style.backgroundColor = secondaryColor;
    const accentPreview = document.getElementById('accent-color-preview');
    if (accentPreview) accentPreview.style.backgroundColor = accentColor;
  }

  function updateColorSwatches() {
    const primaryColor = previewConfig.primaryColor;
    const primarySwatchBtns = document.querySelectorAll('.color-swatch[data-color]');
    primarySwatchBtns.forEach(btn => {
      const swatchColor = btn.getAttribute('data-color');
      if (swatchColor === primaryColor) {
        btn.classList.add('border-white');
        btn.classList.remove('border-transparent');
      } else {
        btn.classList.remove('border-white');
        btn.classList.add('border-transparent');
      }
    });
  }

  document.getElementById('logo-light-upload-area')?.addEventListener('click', () => {
    document.getElementById('logo-light-input')?.click();
  });
  document.getElementById('logo-dark-upload-area')?.addEventListener('click', () => {
    document.getElementById('logo-dark-input')?.click();
  });
  document.getElementById('favicon-light-upload-area')?.addEventListener('click', () => {
    document.getElementById('favicon-light-input')?.click();
  });
  document.getElementById('favicon-dark-upload-area')?.addEventListener('click', () => {
    document.getElementById('favicon-dark-input')?.click();
  });

  ['logo-light', 'logo-dark', 'favicon-light', 'favicon-dark'].forEach(id => {
    document.getElementById(`${id}-upload-area`)?.addEventListener('dragover', (e) => {
      e.preventDefault();
      (e.target as HTMLElement).closest('.border-dashed')?.classList.add('border-primary');
    });
  });

  document.getElementById('logo-light-input')?.addEventListener('change', (e) => {
    const input = e.target as HTMLInputElement;
    if (input.files?.[0]) handleLogoLightUpload(input.files[0]);
  });
  document.getElementById('logo-dark-input')?.addEventListener('change', (e) => {
    const input = e.target as HTMLInputElement;
    if (input.files?.[0]) handleLogoDarkUpload(input.files[0]);
  });
  document.getElementById('favicon-light-input')?.addEventListener('change', (e) => {
    const input = e.target as HTMLInputElement;
    if (input.files?.[0]) handleFaviconLightUpload(input.files[0]);
  });
  document.getElementById('favicon-dark-input')?.addEventListener('change', (e) => {
    const input = e.target as HTMLInputElement;
    if (input.files?.[0]) handleFaviconDarkUpload(input.files[0]);
  });

  document.querySelectorAll('.color-type-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.getAttribute('data-type');
      if (type) selectColorType(type);
    });
  });

  document.querySelectorAll('.color-swatch').forEach(btn => {
    btn.addEventListener('click', () => {
      const color = btn.getAttribute('data-color');
      if (color) selectColor(color);
    });
  });

  function selectColorType(type: string) {
    selectedColorType = type;
    document.querySelectorAll('.color-type-btn').forEach(btn => {
      const btnType = btn.getAttribute('data-type');
      if (btnType === type) {
        btn.classList.add('border-primary');
        btn.classList.remove('border-transparent');
      } else {
        btn.classList.remove('border-primary');
        btn.classList.add('border-transparent');
      }
    });
    document.querySelectorAll('.color-type-btn').forEach(btn => {
      const btnType = btn.getAttribute('data-type');
      const span = btn.querySelector('span');
      if (span && btnType) {
        const colors: Record<string, string> = {
          primary: previewConfig.primaryColor,
          secondary: previewConfig.secondaryColor,
          accent: previewConfig.accentColor
        };
        span.style.backgroundColor = colors[btnType] || '#d2bbff';
      }
    });
  }

  function selectColor(color: string) {
    if (selectedColorType === 'primary') {
      previewConfig.primaryColor = color;
      document.getElementById('primary-color')!.value = color;
    } else if (selectedColorType === 'secondary') {
      previewConfig.secondaryColor = color;
      document.getElementById('secondary-color')!.value = color;
    } else if (selectedColorType === 'accent') {
      previewConfig.accentColor = color;
      document.getElementById('accent-color')!.value = color;
    }
    updatePreview();
    updateColorSwatches();
    document.querySelectorAll('.color-type-btn').forEach(btn => {
      const btnType = btn.getAttribute('data-type');
      const span = btn.querySelector('span');
      if (span && btnType) {
        const colors: Record<string, string> = {
          primary: previewConfig.primaryColor,
          secondary: previewConfig.secondaryColor,
          accent: previewConfig.accentColor
        };
        span.style.backgroundColor = colors[btnType] || '#d2bbff';
      }
    });
  }

  async function handleLogoLightUpload(file: File) {
    if (!file.name.endsWith('.svg')) { alert('Please upload SVG only'); return; }
    try {
      const { upload_url, object_key } = await getPresignedURL('logo_light', file.name);
      await fetch(upload_url, { method: 'PUT', body: file, headers: { 'Content-Type': 'image/svg+xml' } });
      await confirmUpload(object_key, 'logo_light');
      document.getElementById('logo-light-name')!.textContent = file.name;
      document.getElementById('logo-light-upload-area')!.classList.add('hidden');
      document.getElementById('logo-light-preview')!.classList.remove('hidden');
      const previewImg = document.getElementById('logo-light-preview-img');
      if (previewImg) {
        const reader = new FileReader();
        reader.onload = (e) => {
          previewImg.innerHTML = `<img src="${e.target?.result}" class="w-full h-full object-contain" />`;
          const logo = document.getElementById('preview-logo');
          if (logo) logo.innerHTML = `<img src="${e.target?.result}" class="w-full h-full object-contain" />`;
        };
        reader.readAsDataURL(file);
      }
    } catch (err) { console.error(err); alert('Upload failed'); }
  }

