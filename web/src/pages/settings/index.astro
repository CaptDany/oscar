  function removeLogoLight() {
    document.getElementById('logo-light-input')!.value = '';
    document.getElementById('logo-light-upload-area')!.classList.remove('hidden');
    document.getElementById('logo-light-preview')!.classList.add('hidden');
    const logo = document.getElementById('preview-logo');
    if (logo) logo.innerHTML = `<span class="material-symbols-outlined text-white text-sm" style="font-variation-settings: 'FILL' 1;">architecture</span>`;
  }
  function removeLogoDark() {
    document.getElementById('logo-dark-input')!.value = '';
    document.getElementById('logo-dark-upload-area')!.classList.remove('hidden');
    document.getElementById('logo-dark-preview')!.classList.add('hidden');
  }
  function removeFaviconLight() {
    document.getElementById('favicon-light-input')!.value = '';
