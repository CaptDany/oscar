---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Companies">
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Companies</h1>
      <p class="text-gray-500">Manage your organizations and accounts</p>
    </div>
    <button id="add-company-btn" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      Add Company
    </button>
  </div>

  <!-- Filters -->
  <div class="mb-6 flex gap-4">
    <div class="flex-1">
      <input type="text" id="search-input" placeholder="Search companies..." class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
    </div>
  </div>

  <!-- Companies Grid -->
  <div id="companies-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <div class="col-span-full text-center py-12 text-gray-400">
      <svg class="w-8 h-8 mx-auto mb-2 animate-spin" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      Loading companies...
    </div>
  </div>

  <!-- Pagination -->
  <div id="pagination" class="mt-6 flex items-center justify-between">
    <p class="text-sm text-gray-500">Showing <span id="showing-start">0</span> to <span id="showing-end">0</span> of <span id="total-count">0</span> results</p>
    <div class="flex gap-2">
      <button id="prev-btn" class="px-3 py-1 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 disabled:opacity-50" disabled>Previous</button>
      <button id="next-btn" class="px-3 py-1 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 disabled:opacity-50" disabled>Next</button>
    </div>
  </div>

  <!-- Add/Edit Modal -->
  <div id="company-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md mx-4">
      <div class="p-6 border-b border-gray-200">
        <h2 id="modal-title" class="text-lg font-semibold text-gray-900">Add Company</h2>
      </div>
      <form id="company-form" class="p-6 space-y-4">
        <input type="hidden" id="company-id">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
          <input type="text" id="company-name" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Domain</label>
          <input type="url" id="company-domain" placeholder="https://example.com" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
          <input type="tel" id="company-phone" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Address</label>
          <input type="text" id="company-address" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
        </div>
        <div class="flex justify-end gap-3 pt-4">
          <button type="button" id="cancel-btn" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { auth, api } from '../lib/api';

    let currentPage = 1;
    const limit = 20;
    let currentSearch = '';

    async function loadCompanies() {
      const token = auth.token;
      if (!token) {
        window.location.href = '/login';
        return;
      }

      try {
        const data = await api.companies.list(token, {
          limit,
          offset: (currentPage - 1) * limit,
          search: currentSearch,
          includeTotal: true,
        });

        const grid = document.getElementById('companies-grid')!;
        
        if (data.data && data.data.length > 0) {
          grid.innerHTML = data.data.map((company: any) => `
            <div class="bg-white rounded-xl shadow-sm p-6 hover:shadow-md transition-shadow cursor-pointer" onclick="editCompany('${company.id}')">
              <div class="flex items-start justify-between mb-4">
                <div class="w-12 h-12 rounded-lg bg-purple-100 flex items-center justify-center">
                  <span class="text-purple-600 font-bold text-lg">${(company.name || 'C')[0]}</span>
                </div>
                <button onclick="event.stopPropagation(); deleteCompany('${company.id}')" class="text-gray-400 hover:text-red-600">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 mb-1">${company.name || 'Unnamed'}</h3>
              <p class="text-sm text-gray-500 mb-3">${company.domain || 'No website'}</p>
              <div class="flex items-center gap-4 text-sm text-gray-500">
                ${company.phone ? `<span class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  ${company.phone}
                </span>` : ''}
              </div>
            </div>
          `).join('');
        } else {
          grid.innerHTML = `
            <div class="col-span-full text-center py-12 text-gray-400">
              No companies found. Add your first company to get started.
            </div>
          `;
        }

        const total = data.meta?.total || 0;
        const start = (currentPage - 1) * limit + 1;
        const end = Math.min(currentPage * limit, total);
        
        document.getElementById('showing-start')!.textContent = total > 0 ? start.toString() : '0';
        document.getElementById('showing-end')!.textContent = end.toString();
        document.getElementById('total-count')!.textContent = total.toString();
        
        const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
        const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = end >= total;

      } catch (error: any) {
        console.error('Failed to load companies:', error);
        if (error.message?.includes('Unauthorized')) {
          auth.clear();
          window.location.href = '/login';
        }
      }
    }

    function openModal(company?: any) {
      const modal = document.getElementById('company-modal')!;
      const title = document.getElementById('modal-title')!;
      
      if (company) {
        title.textContent = 'Edit Company';
        (document.getElementById('company-id') as HTMLInputElement).value = company.id;
        (document.getElementById('company-name') as HTMLInputElement).value = company.name || '';
        (document.getElementById('company-domain') as HTMLInputElement).value = company.domain || '';
        (document.getElementById('company-phone') as HTMLInputElement).value = company.phone || '';
        (document.getElementById('company-address') as HTMLInputElement).value = company.address || '';
      } else {
        title.textContent = 'Add Company';
        (document.getElementById('company-id') as HTMLInputElement).value = '';
        (document.getElementById('company-form') as HTMLFormElement).reset();
      }
      
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeModal() {
      const modal = document.getElementById('company-modal')!;
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    (window as any).editCompany = async function(id: string) {
      try {
        const company = await api.companies.get(auth.token!, id);
        openModal(company);
      } catch (error) {
        console.error('Failed to load company:', error);
      }
    };

    (window as any).deleteCompany = async function(id: string) {
      if (!confirm('Are you sure you want to delete this company?')) return;
      
      try {
        await api.companies.delete(auth.token!, id);
        loadCompanies();
      } catch (error) {
        console.error('Failed to delete company:', error);
        alert('Failed to delete company');
      }
    };

    document.addEventListener('DOMContentLoaded', () => {
      loadCompanies();

      document.getElementById('add-company-btn')?.addEventListener('click', () => openModal());
      document.getElementById('cancel-btn')?.addEventListener('click', closeModal);
      
      document.getElementById('company-modal')?.addEventListener('click', (e) => {
        if (e.target === e.currentTarget) closeModal();
      });

      let searchTimeout: number;
      document.getElementById('search-input')?.addEventListener('input', (e) => {
        clearTimeout(searchTimeout);
        searchTimeout = window.setTimeout(() => {
          currentSearch = (e.target as HTMLInputElement).value;
          currentPage = 1;
          loadCompanies();
        }, 300);
      });

      document.getElementById('prev-btn')?.addEventListener('click', () => {
        if (currentPage > 1) {
          currentPage--;
          loadCompanies();
        }
      });

      document.getElementById('next-btn')?.addEventListener('click', () => {
        currentPage++;
        loadCompanies();
      });

      document.getElementById('company-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const id = (document.getElementById('company-id') as HTMLInputElement).value;
        const data: any = {
          name: (document.getElementById('company-name') as HTMLInputElement).value,
        };
        
        const domain = (document.getElementById('company-domain') as HTMLInputElement).value;
        if (domain) data.domain = domain;
        
        const phone = (document.getElementById('company-phone') as HTMLInputElement).value;
        if (phone) data.phone = phone;
        
        const address = (document.getElementById('company-address') as HTMLInputElement).value;
        if (address) data.address = address;

        try {
          if (id) {
            await api.companies.update(auth.token!, id, data);
          } else {
            await api.companies.create(auth.token!, data);
          }
          closeModal();
          loadCompanies();
        } catch (error) {
          console.error('Failed to save company:', error);
          alert('Failed to save company');
        }
      });
    });
  </script>
</AppLayout>
