---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Deals">
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Deals</h1>
      <p class="text-gray-500">Track and manage your sales pipeline</p>
    </div>
    <button id="add-deal-btn" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      Add Deal
    </button>
  </div>

  <!-- Filters -->
  <div class="mb-6 flex gap-4">
    <div class="flex-1">
      <input type="text" id="search-input" placeholder="Search deals..." class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
    </div>
  </div>

  <!-- Deals Table -->
  <div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Deal</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Value</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Stage</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Expected Close</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody id="deals-table-body" class="divide-y divide-gray-200">
          <tr>
            <td colspan="6" class="px-6 py-12 text-center text-gray-400">
              <svg class="w-8 h-8 mx-auto mb-2 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              Loading deals...
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  <div id="pagination" class="mt-4 flex items-center justify-between">
    <p class="text-sm text-gray-500">Showing <span id="showing-start">0</span> to <span id="showing-end">0</span> of <span id="total-count">0</span> results</p>
    <div class="flex gap-2">
      <button id="prev-btn" class="px-3 py-1 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 disabled:opacity-50" disabled>Previous</button>
      <button id="next-btn" class="px-3 py-1 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 disabled:opacity-50" disabled>Next</button>
    </div>
  </div>

  <!-- Add/Edit Modal -->
  <div id="deal-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md mx-4">
      <div class="p-6 border-b border-gray-200">
        <h2 id="modal-title" class="text-lg font-semibold text-gray-900">Add Deal</h2>
      </div>
      <form id="deal-form" class="p-6 space-y-4">
        <input type="hidden" id="deal-id">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
          <input type="text" id="deal-title" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Value</label>
          <input type="number" id="deal-value" min="0" step="0.01" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Expected Close Date</label>
          <input type="date" id="deal-close-date" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
          <select id="deal-status" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
            <option value="open">Open</option>
            <option value="won">Won</option>
            <option value="lost">Lost</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Company</label>
          <select id="deal-company" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
            <option value="">No company</option>
          </select>
        </div>
        <div class="flex justify-end gap-3 pt-4">
          <button type="button" id="cancel-btn" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { auth, api } from '../lib/api';

    let currentPage = 1;
    const limit = 20;
    let currentSearch = '';
    let companiesCache: any[] = [];

    function formatCurrency(value: number): string {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      }).format(value || 0);
    }

    function formatDate(dateStr: string): string {
      const date = new Date(dateStr);
      const mm = String(date.getMonth() + 1).padStart(2, '0');
      const dd = String(date.getDate()).padStart(2, '0');
      const yyyy = date.getFullYear();
      return `${mm}/${dd}/${yyyy}`;
    }

    async function loadDeals() {
      const token = auth.token;
      if (!token) {
        window.location.href = '/login';
        return;
      }

      try {
        const data = await api.deals.list(token, {
          limit,
          offset: (currentPage - 1) * limit,
          search: currentSearch,
        });

        const tbody = document.getElementById('deals-table-body')!;
        
        if (data.data && data.data.length > 0) {
          tbody.innerHTML = data.data.map((deal: any) => `
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4">
                <div class="text-sm font-medium text-gray-900">${deal.title || 'Untitled Deal'}</div>
                <div class="text-xs text-gray-500">${deal.company_name || 'No company'}</div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">${formatCurrency(deal.value)}</td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-2 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-800">${deal.stage_name || 'No stage'}</span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-2 py-1 text-xs font-medium rounded-full ${
                  deal.status === 'won' ? 'bg-green-100 text-green-800' :
                  deal.status === 'lost' ? 'bg-red-100 text-red-800' :
                  'bg-gray-100 text-gray-800'
                }">${(deal.status || 'open').charAt(0).toUpperCase() + (deal.status || 'open').slice(1)}</span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${deal.expected_close_date ? formatDate(deal.expected_close_date) : '-'}</td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                <button onclick="editDeal('${deal.id}')" class="text-primary-600 hover:text-primary-900 mr-3">Edit</button>
                <button onclick="deleteDeal('${deal.id}')" class="text-red-600 hover:text-red-900">Delete</button>
              </td>
            </tr>
          `).join('');
        } else {
          tbody.innerHTML = `
            <tr>
              <td colspan="6" class="px-6 py-12 text-center text-gray-400">
                No deals found. Add your first deal to get started.
              </td>
            </tr>
          `;
        }

        const total = data.meta?.total || 0;
        const start = (currentPage - 1) * limit + 1;
        const end = Math.min(currentPage * limit, total);
        
        document.getElementById('showing-start')!.textContent = total > 0 ? start.toString() : '0';
        document.getElementById('showing-end')!.textContent = end.toString();
        document.getElementById('total-count')!.textContent = total.toString();
        
        const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
        const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = end >= total;

      } catch (error: any) {
        console.error('Failed to load deals:', error);
        if (error.message?.includes('Unauthorized')) {
          auth.clear();
          window.location.href = '/login';
        }
      }
    }

    async function loadCompanies() {
      if (companiesCache.length > 0) return companiesCache;
      
      try {
        const data = await api.companies.list(auth.token!, { limit: 100, includeTotal: true });
        companiesCache = data.data || [];
      } catch (error) {
        console.error('Failed to load companies:', error);
        companiesCache = [];
      }
      return companiesCache;
    }

    async function openModal(deal?: any) {
      const modal = document.getElementById('deal-modal')!;
      const title = document.getElementById('modal-title')!;
      const companySelect = document.getElementById('deal-company') as HTMLSelectElement;
      
      const companies = await loadCompanies();
      companySelect.innerHTML = '<option value="">No company</option>' + 
        companies.map((c: any) => `<option value="${c.id}">${c.name}</option>`).join('');
      
      if (deal) {
        title.textContent = 'Edit Deal';
        (document.getElementById('deal-id') as HTMLInputElement).value = deal.id;
        (document.getElementById('deal-title') as HTMLInputElement).value = deal.title || '';
        (document.getElementById('deal-value') as HTMLInputElement).value = deal.value || '';
        (document.getElementById('deal-status') as HTMLSelectElement).value = deal.status || 'open';
        companySelect.value = deal.company_id || '';
        if (deal.expected_close_date) {
          (document.getElementById('deal-close-date') as HTMLInputElement).value = deal.expected_close_date.split('T')[0];
        }
      } else {
        title.textContent = 'Add Deal';
        (document.getElementById('deal-id') as HTMLInputElement).value = '';
        (document.getElementById('deal-form') as HTMLFormElement).reset();
        companySelect.value = '';
      }
      
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeModal() {
      const modal = document.getElementById('deal-modal')!;
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    (window as any).editDeal = async function(id: string) {
      try {
        const deal = await api.deals.get(auth.token!, id);
        openModal(deal);
      } catch (error) {
        console.error('Failed to load deal:', error);
      }
    };

    (window as any).deleteDeal = async function(id: string) {
      if (!confirm('Are you sure you want to delete this deal?')) return;
      
      try {
        await api.deals.delete(auth.token!, id);
        loadDeals();
      } catch (error) {
        console.error('Failed to delete deal:', error);
        alert('Failed to delete deal');
      }
    };

    document.addEventListener('DOMContentLoaded', () => {
      loadDeals();

      document.getElementById('add-deal-btn')?.addEventListener('click', () => openModal());
      document.getElementById('cancel-btn')?.addEventListener('click', closeModal);
      
      document.getElementById('deal-modal')?.addEventListener('click', (e) => {
        if (e.target === e.currentTarget) closeModal();
      });

      let searchTimeout: number;
      document.getElementById('search-input')?.addEventListener('input', (e) => {
        clearTimeout(searchTimeout);
        searchTimeout = window.setTimeout(() => {
          currentSearch = (e.target as HTMLInputElement).value;
          currentPage = 1;
          loadDeals();
        }, 300);
      });

      document.getElementById('prev-btn')?.addEventListener('click', () => {
        if (currentPage > 1) {
          currentPage--;
          loadDeals();
        }
      });

      document.getElementById('next-btn')?.addEventListener('click', () => {
        currentPage++;
        loadDeals();
      });

      document.getElementById('deal-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const id = (document.getElementById('deal-id') as HTMLInputElement).value;
        const data: any = {
          title: (document.getElementById('deal-title') as HTMLInputElement).value,
          status: (document.getElementById('deal-status') as HTMLSelectElement).value,
        };
        
        const value = (document.getElementById('deal-value') as HTMLInputElement).value;
        if (value) data.value = parseFloat(value);
        
        const closeDate = (document.getElementById('deal-close-date') as HTMLInputElement).value;
        if (closeDate) data.expected_close_date = closeDate;

        const companyId = (document.getElementById('deal-company') as HTMLSelectElement).value;
        if (companyId) data.company_id = companyId;

        try {
          if (id) {
            await api.deals.update(auth.token!, id, data);
          } else {
            await api.deals.create(auth.token!, data);
          }
          closeModal();
          loadDeals();
        } catch (error) {
          console.error('Failed to save deal:', error);
          alert('Failed to save deal');
        }
      });
    });
  </script>
</AppLayout>
