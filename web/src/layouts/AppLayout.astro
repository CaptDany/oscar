---
import '../styles/global.css';
import SideNavBar from '../components/SideNavBar.astro';
import TopNavBar from '../components/TopNavBar.astro';
import CommandPalette from '../components/CommandPalette.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | oscar</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📊</text></svg>">
</head>
<body class="bg-background text-on-background antialiased">
  <div class="fixed inset-0 grain-overlay z-[100]"></div>

  <div class="flex h-screen">
    <SideNavBar currentPath={currentPath} />

    <main class="flex-1 flex flex-col bg-surface relative">
      <TopNavBar />
      <div class="flex-1 overflow-y-auto">
        <slot />
      </div>
    </main>
  </div>

  <CommandPalette />
</body>
</html>
