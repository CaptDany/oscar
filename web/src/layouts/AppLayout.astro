---
import Layout from './Layout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;

interface User {
  id: string;
  first_name: string;
  last_name: string;
  email: string;
  roles: string[];
}

let user: User | null = null;
let isAuthenticated = false;

if (typeof window !== 'undefined') {
  const stored = localStorage.getItem('oscar_auth');
  if (stored) {
    try {
      const parsed = JSON.parse(stored);
      user = parsed.user;
      isAuthenticated = !!parsed.token;
    } catch {}
  }
}
---

<Layout title={`${title} | Oscar`}>
  <div class="min-h-screen bg-gray-50">
    <!-- Sidebar -->
    <aside class="fixed left-0 top-0 h-full w-64 bg-white border-r border-gray-200 flex flex-col">
      <div class="p-6 border-b border-gray-100">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-primary-600 flex items-center justify-center">
            <span class="text-white font-bold text-lg">O</span>
          </div>
          <span class="font-semibold text-gray-900">Oscar</span>
        </div>
      </div>

      <nav class="flex-1 px-4 py-4 space-y-1 overflow-y-auto">
        <a href="/dashboard" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors" data-page="dashboard">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          <span>Dashboard</span>
        </a>

        <a href="/persons" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors" data-page="persons">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>Persons</span>
        </a>

        <a href="/companies" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors" data-page="companies">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
          <span>Companies</span>
        </a>

        <a href="/deals" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors" data-page="deals">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Deals</span>
        </a>

        <a href="/activities" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors" data-page="activities">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
          <span>Activities</span>
        </a>

        <a href="/pipeline" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors" data-page="pipeline">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
          </svg>
          <span>Pipeline</span>
        </a>

        <a href="/users" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors" data-page="users">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <span>Users</span>
        </a>
      </nav>

      <div class="p-4 border-t border-gray-200">
        <div class="flex items-center gap-3">
          <a href="/profile" class="flex items-center gap-3 flex-1 min-w-0 hover:opacity-80 transition-opacity">
            <div id="user-avatar" class="w-10 h-10 rounded-full bg-gray-200 flex items-center justify-center overflow-hidden flex-shrink-0">
              <span id="avatar-initials" class="text-gray-600 font-medium">--</span>
              <img id="avatar-image" src="" alt="" class="w-full h-full object-cover hidden" />
            </div>
            <div class="flex-1 min-w-0">
              <p id="user-name" class="text-sm font-medium text-gray-900 truncate">Loading...</p>
              <p id="user-role" class="text-xs text-gray-500 truncate">-</p>
            </div>
          </a>
          <button id="logout-btn" class="p-2 text-gray-400 hover:text-gray-600 transition-colors" title="Logout">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
          </button>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="ml-64 p-8">
      <slot />
    </main>
  </div>

  <script>
    import { auth, api } from '../lib/api';

    function hashCode(str: string): number {
      let hash = 0;
      for (let i = 0; i < str.length; i++) {
        const char = str.charCodeAt(i);
        hash = ((hash << 5) - hash) + char;
        hash = hash & hash;
      }
      return Math.abs(hash);
    }

    function getAvatarColor(userId: string): string {
      const colors = [
        'bg-red-500', 'bg-orange-500', 'bg-amber-500', 'bg-yellow-500',
        'bg-lime-500', 'bg-green-500', 'bg-emerald-500', 'bg-teal-500',
        'bg-cyan-500', 'bg-sky-500', 'bg-blue-500', 'bg-indigo-500',
        'bg-violet-500', 'bg-purple-500', 'bg-fuchsia-500', 'bg-pink-500',
      ];
      return colors[hashCode(userId) % colors.length];
    }

    function updateAvatarDisplay(userId: string, firstName: string, lastName: string, avatarUrl: string | null) {
      const initials = `${firstName?.[0] || ''}${lastName?.[0] || ''}`.toUpperCase();
      const avatarInitials = document.getElementById('avatar-initials');
      const avatarImage = document.getElementById('avatar-image') as HTMLImageElement;
      const userAvatar = document.getElementById('user-avatar');

      if (avatarUrl) {
        avatarImage.src = avatarUrl;
        avatarImage.classList.remove('hidden');
        avatarImage.classList.add('block');
        if (avatarInitials) avatarInitials.classList.add('hidden');
        if (userAvatar) {
          userAvatar.classList.remove('bg-gray-200');
          userAvatar.className = 'w-10 h-10 rounded-full flex items-center justify-center overflow-hidden flex-shrink-0';
        }
      } else {
        avatarImage.classList.add('hidden');
        avatarImage.classList.remove('block');
        if (avatarInitials) {
          avatarInitials.classList.remove('hidden');
          avatarInitials.textContent = initials || '--';
          avatarInitials.className = 'text-white font-medium';
        }
        if (userAvatar) {
          userAvatar.className = `w-10 h-10 rounded-full flex items-center justify-center overflow-hidden flex-shrink-0 ${getAvatarColor(userId)}`;
        }
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      const stored = localStorage.getItem('oscar_auth');
      if (stored) {
        try {
          const parsed = JSON.parse(stored);
          if (parsed.user) {
            const userName = document.getElementById('user-name');
            const userRole = document.getElementById('user-role');
            
            if (userName) userName.textContent = `${parsed.user.first_name} ${parsed.user.last_name}`;
            if (userRole) userRole.textContent = parsed.user.roles?.[0] || 'User';
            updateAvatarDisplay(parsed.user.id, parsed.user.first_name, parsed.user.last_name, parsed.user.avatar_url);
          }
        } catch {}
      }

      const currentPage = window.location.pathname.split('/')[1] || 'dashboard';
      document.querySelectorAll('.nav-link').forEach(link => {
        if ((link as HTMLElement).dataset.page === currentPage) {
          link.classList.remove('text-gray-600', 'hover:bg-gray-50', 'hover:text-gray-900');
          link.classList.add('bg-primary-50', 'text-primary-700');
        }
      });

      const logoutBtn = document.getElementById('logout-btn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', async () => {
          try {
            const token = auth.token;
            if (token) {
              await api.auth.logout(token);
            }
          } catch {}
          auth.clear();
          window.location.href = '/login';
        });
      }
    });
  </script>
</Layout>
